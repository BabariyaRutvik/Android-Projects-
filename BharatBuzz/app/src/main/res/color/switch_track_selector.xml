<?xml version="1.0" encoding="utf-8"?>
<selector xmlns:android="http://schemas.android.com/apk/res/android">
    <!-- Color when the switch is ON -->
    <item android:alpha="0.5" android:color="@color/active_blue" android:state_checked="true" />
    <!-- Color when the switch is OFF -->
    <item android:alpha="0.2" android:color="@color/inactive_grey" android:state_checked="false" />
</selector>