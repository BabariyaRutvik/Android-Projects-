<?xml version="1.0" encoding="utf-8"?>
<com.google.android.material.card.MaterialCardView xmlns:android="http://schemas.android.com/apk/res/android"
    xmlns:app="http://schemas.android.com/apk/res-auto"
    android:layout_width="match_parent"
    android:layout_height="wrap_content"
    app:cardCornerRadius="28dp"
    app:cardElevation="0dp"
    app:cardBackgroundColor="@color/white">

    <androidx.constraintlayout.widget.ConstraintLayout
        android:layout_width="match_parent"
        android:layout_height="wrap_content"
        android:padding="24dp">

        <TextView
            android:id="@+id/txtTitle"
            android:layout_width="wrap_content"
            android:layout_height="wrap_content"
            android:text="Format"
            android:textColor="@color/black"
            android:textSize="22sp"
            android:fontFamily="sans-serif-medium"
            app:layout_constraintStart_toStartOf="parent"
            app:layout_constraintTop_toTopOf="parent" />

        <ImageView
            android:id="@+id/btnClose"
            android:layout_width="24dp"
            android:layout_height="24dp"
            android:src="@drawable/ic_close"
            app:tint="@color/gray_text"
            app:layout_constraintEnd_toEndOf="parent"
            app:layout_constraintTop_toTopOf="parent" />

        <LinearLayout
            android:id="@+id/layoutHeading"
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:layout_marginTop="24dp"
            android:orientation="horizontal"
            android:gravity="center_vertical"
            app:layout_constraintTop_toBottomOf="@id/txtTitle">

            <TextView
                android:id="@+id/btnHeading1"
                android:layout_width="wrap_content"
                android:layout_height="wrap_content"
                android:text="Heading 1"
                android:textColor="@color/black"
                android:textSize="22sp"
                android:textStyle="bold"
                android:fontFamily="sans-serif-medium"
                android:padding="8dp"
                android:background="?attr/selectableItemBackground" />

            <TextView
                android:id="@+id/btnHeading2"
                android:layout_width="wrap_content"
                android:layout_height="wrap_content"
                android:layout_marginStart="20dp"
                android:text="Heading 2"
                android:textColor="@color/black"
                android:textSize="18sp"
                android:textStyle="bold"
                android:fontFamily="sans-serif-medium"
                android:padding="8dp"
                android:background="?attr/selectableItemBackground" />

            <TextView
                android:id="@+id/btnHeading3"
                android:layout_width="wrap_content"
                android:layout_height="wrap_content"
                android:layout_marginStart="20dp"
                android:text="Heading 3"
                android:textColor="@color/black"
                android:textSize="16sp"
                android:textStyle="bold"
                android:fontFamily="sans-serif-medium"
                android:padding="8dp"
                android:background="?attr/selectableItemBackground" />

            <View
                android:layout_width="0dp"
                android:layout_height="0dp"
                android:layout_weight="1" />

            <TextView
                android:id="@+id/btnNormalText"
                android:layout_width="wrap_content"
                android:layout_height="wrap_content"
                android:text="TXT"
                android:textColor="@color/white"
                android:background="@drawable/bg_circle_primary"
                android:paddingHorizontal="16dp"
                android:paddingVertical="8dp" />

        </LinearLayout>

        <LinearLayout
            android:id="@+id/layoutStyleButtons"
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:layout_marginTop="20dp"
            android:orientation="horizontal"
            app:layout_constraintTop_toBottomOf="@id/layoutHeading"
            app:layout_constraintBottom_toBottomOf="parent">

            <LinearLayout
                android:layout_width="wrap_content"
                android:layout_height="wrap_content"
                android:background="#F0F4F8"
                android:padding="4dp"
                android:orientation="horizontal">

                <ImageView
                    android:id="@+id/btnBold"
                    android:layout_width="48dp"
                    android:layout_height="40dp"
                    android:src="@drawable/ic_format_bold"
                    android:padding="10dp"
                    app:tint="@color/black" />

                <ImageView
                    android:id="@+id/btnItalic"
                    android:layout_width="48dp"
                    android:layout_height="40dp"
                    android:src="@drawable/ic_format_italic"
                    android:padding="10dp"
                    app:tint="@color/black" />

                <ImageView
                    android:id="@+id/btnUnderline"
                    android:layout_width="48dp"
                    android:layout_height="40dp"
                    android:src="@drawable/ic_format_underlined"
                    android:padding="10dp"
                    app:tint="@color/black" />
            </LinearLayout>

            <View
                android:layout_width="16dp"
                android:layout_height="0dp" />

            <LinearLayout
                android:layout_width="wrap_content"
                android:layout_height="wrap_content"
                android:background="#F0F4F8"
                android:padding="4dp"
                android:orientation="horizontal">

                <ImageView
                    android:id="@+id/btnBulletList"
                    android:layout_width="48dp"
                    android:layout_height="40dp"
                    android:src="@drawable/ic_format_list_bulleted"
                    android:padding="10dp"
                    app:tint="@color/black" />
            </LinearLayout>

            <View
                android:layout_width="16dp"
                android:layout_height="0dp" />

            <LinearLayout
                android:layout_width="wrap_content"
                android:layout_height="wrap_content"
                android:background="#F0F4F8"
                android:padding="4dp"
                android:orientation="horizontal">

                <ImageView
                    android:id="@+id/btnNumberedList"
                    android:layout_width="48dp"
                    android:layout_height="40dp"
                    android:src="@drawable/ic_format_list_numbered"
                    android:padding="10dp"
                    app:tint="@color/black" />
            </LinearLayout>

        </LinearLayout>

    </androidx.constraintlayout.widget.ConstraintLayout>

</com.google.android.material.card.MaterialCardView>
