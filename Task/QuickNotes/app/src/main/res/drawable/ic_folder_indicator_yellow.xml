<layer-list xmlns:android="http://schemas.android.com/apk/res/android">
    <!-- Outer Ring -->
    <item>
        <shape android:shape="oval">
            <stroke
                android:width="1.5dp"
                android:color="#FBC02D" />
            <size
                android:width="20dp"
                android:height="20dp" />
        </shape>
    </item>
    <!-- Inner Solid Circle -->
    <item
        android:bottom="5dp"
        android:left="5dp"
        android:right="5dp"
        android:top="5dp">
        <shape android:shape="oval">
            <solid android:color="#FBC02D" />
        </shape>
    </item>
</layer-list>