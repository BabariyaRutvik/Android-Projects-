<?xml version="1.0" encoding="utf-8"?>
<androidx.constraintlayout.widget.ConstraintLayout xmlns:android="http://schemas.android.com/apk/res/android"
    xmlns:app="http://schemas.android.com/apk/res-auto"
    xmlns:tools="http://schemas.android.com/tools"
    android:id="@+id/main"
    android:layout_width="match_parent"
    android:layout_height="match_parent"
    android:background="@color/screen_background"
    tools:context=".Activity.UnitConverterCalculatorActivity">

    <!-- Custom Toolbar -->
    <com.google.android.material.appbar.AppBarLayout
        android:id="@+id/app_bar"
        android:layout_width="match_parent"
        android:layout_height="wrap_content"
        android:background="@color/screen_background"
        app:layout_constraintTop_toTopOf="parent">

        <com.google.android.material.appbar.MaterialToolbar
            android:id="@+id/toolbar"
            android:layout_width="match_parent"
            android:layout_height="?attr/actionBarSize"
            android:background="@color/screen_background"
            app:navigationIcon="@drawable/ic_back"
            app:navigationContentDescription="@string/desc_back"
            app:title="@string/unit_converter"
            app:titleTextAppearance="@style/ToolbarTitleStyle" />

    </com.google.android.material.appbar.AppBarLayout>

    <androidx.recyclerview.widget.RecyclerView
        android:id="@+id/category_recyerview"
        android:layout_width="match_parent"
        android:layout_height="wrap_content"
        android:orientation="horizontal"
        app:layout_constraintTop_toBottomOf="@id/app_bar"
        android:paddingVertical="5dp"
        android:paddingHorizontal="5dp"
        app:layoutManager="androidx.recyclerview.widget.LinearLayoutManager"/>

    <!-- Main Content -->
    <androidx.core.widget.NestedScrollView
        android:id="@+id/unit_scroll"
        android:layout_width="match_parent"
        android:layout_height="0dp"
        android:fillViewport="true"
        android:overScrollMode="never"
        app:layout_constraintBottom_toTopOf="@+id/keypad_unit"
        app:layout_constraintTop_toBottomOf="@id/category_recyerview">

        <androidx.constraintlayout.widget.ConstraintLayout
            android:id="@+id/unit_container"
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:paddingHorizontal="6dp"
            android:paddingTop="4dp"
            android:paddingBottom="12dp">

            <androidx.constraintlayout.widget.ConstraintLayout
                android:id="@+id/input_container_unit"
                android:layout_width="match_parent"
                android:layout_height="wrap_content"
                android:paddingHorizontal="4dp"
                app:layout_constraintTop_toTopOf="parent">

                <!-- From Unit Box -->
                <androidx.constraintlayout.widget.ConstraintLayout
                    android:id="@+id/layout_unit_from"
                    android:layout_width="match_parent"
                    android:layout_height="wrap_content"
                    android:minHeight="80dp"
                    android:background="@drawable/sl_input_bg"
                    android:paddingHorizontal="16dp"
                    android:paddingVertical="12dp"
                    app:layout_constraintTop_toTopOf="parent">

                    <TextView
                        android:id="@+id/text_unit_label_from"
                        android:layout_width="wrap_content"
                        android:layout_height="wrap_content"
                        android:fontFamily="@font/regular"
                        android:text=""
                        android:textColor="@color/text_label_gray"
                        android:textSize="15sp"
                        app:layout_constraintStart_toStartOf="parent"
                        app:layout_constraintTop_toTopOf="parent" />

                    <EditText
                        android:id="@+id/text_unit_value_from"
                        android:layout_width="0dp"
                        android:layout_height="0dp"
                        android:layout_marginTop="4dp"
                        android:background="@android:color/transparent"
                        android:cursorVisible="true"
                        android:focusable="true"
                        android:focusableInTouchMode="true"
                        android:fontFamily="@font/regular"
                        android:gravity="start|center_vertical"
                        android:hint="@string/placeholder_unit"
                        android:importantForAutofill="no"
                        android:inputType="numberDecimal"
                        android:digits="0123456789."
                        android:minHeight="48dp"
                        android:paddingHorizontal="10dp"
                        android:textColor="@color/input_text_color"
                        android:textColorHint="@color/result_text_color"
                        android:textCursorDrawable="@drawable/orange_cursor"
                        android:textSize="18sp"
                        app:layout_constraintBottom_toBottomOf="parent"
                        app:layout_constraintEnd_toStartOf="@+id/layout_unit_picker_from"
                        app:layout_constraintStart_toStartOf="parent"
                        app:layout_constraintTop_toBottomOf="@id/text_unit_label_from" />

                    <androidx.constraintlayout.widget.ConstraintLayout
                        android:id="@+id/layout_unit_picker_from"
                        android:layout_width="wrap_content"
                        android:layout_height="wrap_content"
                        app:layout_constraintBottom_toBottomOf="parent"
                        app:layout_constraintEnd_toEndOf="parent"
                        app:layout_constraintTop_toTopOf="parent">

                        <TextView
                            android:id="@+id/text_unit_code_from"
                            android:layout_width="wrap_content"
                            android:layout_height="wrap_content"
                            android:fontFamily="@font/regular"
                            android:text=""
                            android:textColor="@color/input_text_color"
                            android:textSize="18sp"
                            app:layout_constraintBottom_toBottomOf="parent"
                            app:layout_constraintStart_toStartOf="parent"
                            app:layout_constraintTop_toTopOf="parent" />

                        <ImageView
                            android:layout_width="20dp"
                            android:layout_height="20dp"
                            android:layout_marginStart="4dp"
                            android:contentDescription="@null"
                            android:src="@drawable/currency_con_arrow"
                            app:layout_constraintBottom_toBottomOf="parent"
                            app:layout_constraintStart_toEndOf="@id/text_unit_code_from"
                            app:layout_constraintTop_toTopOf="parent" />

                    </androidx.constraintlayout.widget.ConstraintLayout>

                </androidx.constraintlayout.widget.ConstraintLayout>

                <!-- To Unit Box -->
                <androidx.constraintlayout.widget.ConstraintLayout
                    android:id="@+id/layout_unit_to"
                    android:layout_width="match_parent"
                    android:layout_height="wrap_content"
                    android:minHeight="80dp"
                    android:layout_marginTop="12dp"
                    android:background="@drawable/sl_input_bg"
                    android:paddingHorizontal="16dp"
                    android:paddingVertical="12dp"
                    app:layout_constraintTop_toBottomOf="@id/layout_unit_from">

                    <TextView
                        android:id="@+id/text_unit_label_to"
                        android:layout_width="wrap_content"
                        android:layout_height="wrap_content"
                        android:fontFamily="@font/regular"
                        android:text=""
                        android:textColor="@color/text_label_gray"
                        android:textSize="15sp"
                        app:layout_constraintStart_toStartOf="parent"
                        app:layout_constraintTop_toTopOf="parent" />

                    <TextView
                        android:id="@+id/text_unit_value_to"
                        android:layout_width="0dp"
                        android:layout_height="0dp"
                        android:layout_marginTop="4dp"
                        android:fontFamily="@font/regular"
                        android:gravity="start|center_vertical"
                        android:minHeight="48dp"
                        android:paddingHorizontal="10dp"
                        android:text=""
                        android:textColor="@color/input_text_color"
                        android:textSize="18sp"
                        app:layout_constraintBottom_toBottomOf="parent"
                        app:layout_constraintEnd_toStartOf="@+id/layout_unit_picker_to"
                        app:layout_constraintStart_toStartOf="parent"
                        app:layout_constraintTop_toBottomOf="@id/text_unit_label_to" />

                    <androidx.constraintlayout.widget.ConstraintLayout
                        android:id="@+id/layout_unit_picker_to"
                        android:layout_width="wrap_content"
                        android:layout_height="wrap_content"
                        app:layout_constraintBottom_toBottomOf="parent"
                        app:layout_constraintEnd_toEndOf="parent"
                        app:layout_constraintTop_toTopOf="parent">

                        <TextView
                            android:id="@+id/text_unit_code_to"
                            android:layout_width="wrap_content"
                            android:layout_height="wrap_content"
                            android:fontFamily="@font/regular"
                            android:text=""
                            android:textColor="@color/input_text_color"
                            android:textSize="18sp"
                            app:layout_constraintBottom_toBottomOf="parent"
                            app:layout_constraintStart_toStartOf="parent"
                            app:layout_constraintTop_toTopOf="parent" />

                        <ImageView
                            android:layout_width="20dp"
                            android:layout_height="20dp"
                            android:layout_marginStart="4dp"
                            android:contentDescription="@null"
                            android:src="@drawable/currency_con_arrow"
                            app:layout_constraintBottom_toBottomOf="parent"
                            app:layout_constraintStart_toEndOf="@id/text_unit_code_to"
                            app:layout_constraintTop_toTopOf="parent" />

                    </androidx.constraintlayout.widget.ConstraintLayout>

                </androidx.constraintlayout.widget.ConstraintLayout>

            </androidx.constraintlayout.widget.ConstraintLayout>

        </androidx.constraintlayout.widget.ConstraintLayout>
    </androidx.core.widget.NestedScrollView>

    <!-- Keypad Section -->
    <androidx.constraintlayout.widget.ConstraintLayout
        android:id="@+id/keypad_unit"
        android:layout_width="match_parent"
        android:layout_height="wrap_content"
        android:paddingHorizontal="6dp"
        android:paddingBottom="12dp"
        app:layout_constraintBottom_toBottomOf="parent">

        <androidx.constraintlayout.widget.Guideline
            android:id="@+id/gl_1"
            android:layout_width="wrap_content"
            android:layout_height="wrap_content"
            android:orientation="vertical"
            app:layout_constraintGuide_percent="0.25" />

        <androidx.constraintlayout.widget.Guideline
            android:id="@+id/gl_2"
            android:layout_width="wrap_content"
            android:layout_height="wrap_content"
            android:orientation="vertical"
            app:layout_constraintGuide_percent="0.5" />

        <androidx.constraintlayout.widget.Guideline
            android:id="@+id/gl_3"
            android:layout_width="wrap_content"
            android:layout_height="wrap_content"
            android:orientation="vertical"
            app:layout_constraintGuide_percent="0.75" />

        <!-- Row 1 -->
        <com.google.android.material.button.MaterialButton
            android:id="@+id/btn_unit_7"
            style="@style/CalculatorButtonStyle"
            android:background="@drawable/btn_bg_white"
            android:fontFamily="@font/regular"
            android:text="@string/btn_7"
            android:textColor="@color/input_text_color"
            android:textSize="32sp"
            app:backgroundTint="@null"
            app:layout_constraintEnd_toStartOf="@id/gl_1"
            app:layout_constraintStart_toStartOf="parent"
            app:layout_constraintTop_toTopOf="parent" />

        <com.google.android.material.button.MaterialButton
            android:id="@+id/btn_unit_8"
            style="@style/CalculatorButtonStyle"
            android:background="@drawable/btn_bg_white"
            android:fontFamily="@font/regular"
            android:text="@string/btn_8"
            android:textColor="@color/input_text_color"
            android:textSize="32sp"
            app:backgroundTint="@null"
            app:layout_constraintEnd_toStartOf="@id/gl_2"
            app:layout_constraintStart_toEndOf="@id/gl_1"
            app:layout_constraintTop_toTopOf="parent" />

        <com.google.android.material.button.MaterialButton
            android:id="@+id/btn_unit_9"
            style="@style/CalculatorButtonStyle"
            android:background="@drawable/btn_bg_white"
            android:fontFamily="@font/regular"
            android:text="@string/btn_9"
            android:textColor="@color/input_text_color"
            android:textSize="32sp"
            app:backgroundTint="@null"
            app:layout_constraintEnd_toStartOf="@id/gl_3"
            app:layout_constraintStart_toEndOf="@id/gl_2"
            app:layout_constraintTop_toTopOf="parent" />

        <com.google.android.material.button.MaterialButton
            android:id="@+id/btn_unit_ac"
            style="@style/CalculatorButtonStyle"
            android:background="@drawable/btn_bg_light_red"
            android:fontFamily="@font/regular"
            android:text="@string/btn_ac"
            android:textColor="@color/red_dark"
            android:textSize="26sp"
            app:backgroundTint="@null"
            app:layout_constraintEnd_toEndOf="parent"
            app:layout_constraintStart_toEndOf="@id/gl_3"
            app:layout_constraintTop_toTopOf="parent" />

        <!-- Row 2 -->
        <com.google.android.material.button.MaterialButton
            android:id="@+id/btn_unit_4"
            style="@style/CalculatorButtonStyle"
            android:layout_marginTop="9dp"
            android:background="@drawable/btn_bg_white"
            android:fontFamily="@font/regular"
            android:text="@string/btn_4"
            android:textColor="@color/input_text_color"
            android:textSize="32sp"
            app:backgroundTint="@null"
            app:layout_constraintEnd_toStartOf="@id/gl_1"
            app:layout_constraintStart_toStartOf="parent"
            app:layout_constraintTop_toBottomOf="@id/btn_unit_7" />

        <com.google.android.material.button.MaterialButton
            android:id="@+id/btn_unit_5"
            style="@style/CalculatorButtonStyle"
            android:layout_marginTop="9dp"
            android:background="@drawable/btn_bg_white"
            android:fontFamily="@font/regular"
            android:text="@string/btn_5"
            android:textColor="@color/input_text_color"
            android:textSize="32sp"
            app:backgroundTint="@null"
            app:layout_constraintEnd_toStartOf="@id/gl_2"
            app:layout_constraintStart_toEndOf="@id/gl_1"
            app:layout_constraintTop_toBottomOf="@id/btn_unit_8" />

        <com.google.android.material.button.MaterialButton
            android:id="@+id/btn_unit_6"
            style="@style/CalculatorButtonStyle"
            android:layout_marginTop="9dp"
            android:background="@drawable/btn_bg_white"
            android:fontFamily="@font/regular"
            android:text="@string/btn_6"
            android:textColor="@color/input_text_color"
            android:textSize="32sp"
            app:backgroundTint="@null"
            app:layout_constraintEnd_toStartOf="@id/gl_3"
            app:layout_constraintStart_toEndOf="@id/gl_2"
            app:layout_constraintTop_toBottomOf="@id/btn_unit_9" />

        <com.google.android.material.button.MaterialButton
            android:id="@+id/btn_unit_backspace"
            style="@style/CalculatorButtonStyle"
            android:layout_marginTop="9dp"
            android:background="@drawable/btn_bg_gray"
            android:contentDescription="@string/desc_backspace"
            app:backgroundTint="@null"
            app:icon="@drawable/backspace_calculator_mode"
            app:iconGravity="textStart"
            app:iconPadding="0dp"
            app:iconSize="35dp"
            app:iconTint="@color/input_text_color"
            app:layout_constraintEnd_toEndOf="parent"
            app:layout_constraintStart_toEndOf="@id/gl_3"
            app:layout_constraintTop_toBottomOf="@id/btn_unit_ac" />

        <!-- Row 3 -->
        <com.google.android.material.button.MaterialButton
            android:id="@+id/btn_unit_1"
            style="@style/CalculatorButtonStyle"
            android:layout_marginTop="9dp"
            android:background="@drawable/btn_bg_white"
            android:fontFamily="@font/regular"
            android:text="@string/btn_1"
            android:textColor="@color/input_text_color"
            android:textSize="32sp"
            app:backgroundTint="@null"
            app:layout_constraintEnd_toStartOf="@id/gl_1"
            app:layout_constraintStart_toStartOf="parent"
            app:layout_constraintTop_toBottomOf="@id/btn_unit_4" />

        <com.google.android.material.button.MaterialButton
            android:id="@+id/btn_unit_2"
            style="@style/CalculatorButtonStyle"
            android:layout_marginTop="9dp"
            android:background="@drawable/btn_bg_white"
            android:fontFamily="@font/regular"
            android:text="@string/btn_2"
            android:textColor="@color/input_text_color"
            android:textSize="32sp"
            app:backgroundTint="@null"
            app:layout_constraintEnd_toStartOf="@id/gl_2"
            app:layout_constraintStart_toEndOf="@id/gl_1"
            app:layout_constraintTop_toBottomOf="@id/btn_unit_5" />

        <com.google.android.material.button.MaterialButton
            android:id="@+id/btn_unit_3"
            style="@style/CalculatorButtonStyle"
            android:layout_marginTop="9dp"
            android:background="@drawable/btn_bg_white"
            android:fontFamily="@font/regular"
            android:text="@string/btn_3"
            android:textColor="@color/input_text_color"
            android:textSize="32sp"
            app:backgroundTint="@null"
            app:layout_constraintEnd_toStartOf="@id/gl_3"
            app:layout_constraintStart_toEndOf="@id/gl_2"
            app:layout_constraintTop_toBottomOf="@id/btn_unit_6" />

        <!-- Row 4 -->
        <com.google.android.material.button.MaterialButton
            android:id="@+id/btn_unit_00"
            style="@style/CalculatorButtonStyle"
            android:layout_marginTop="9dp"
            android:background="@drawable/btn_bg_white"
            android:fontFamily="@font/regular"
            android:text="@string/btn_00"
            android:textColor="@color/input_text_color"
            android:textSize="32sp"
            app:backgroundTint="@null"
            app:layout_constraintEnd_toStartOf="@id/gl_1"
            app:layout_constraintStart_toStartOf="parent"
            app:layout_constraintTop_toBottomOf="@id/btn_unit_1" />

        <com.google.android.material.button.MaterialButton
            android:id="@+id/btn_unit_0"
            style="@style/CalculatorButtonStyle"
            android:layout_marginTop="9dp"
            android:background="@drawable/btn_bg_white"
            android:fontFamily="@font/regular"
            android:text="@string/btn_0"
            android:textColor="@color/input_text_color"
            android:textSize="32sp"
            app:backgroundTint="@null"
            app:layout_constraintEnd_toStartOf="@id/gl_2"
            app:layout_constraintStart_toEndOf="@id/gl_1"
            app:layout_constraintTop_toBottomOf="@id/btn_unit_2" />

        <com.google.android.material.button.MaterialButton
            android:id="@+id/btn_unit_dot"
            style="@style/CalculatorButtonStyle"
            android:layout_marginTop="9dp"
            android:background="@drawable/btn_bg_white"
            android:fontFamily="@font/regular"
            android:text="@string/btn_dot"
            android:textColor="@color/input_text_color"
            android:textSize="32sp"
            app:backgroundTint="@null"
            app:layout_constraintEnd_toStartOf="@id/gl_3"
            app:layout_constraintStart_toEndOf="@id/gl_2"
            app:layout_constraintTop_toBottomOf="@id/btn_unit_3" />

        <!-- Swap button spanning 2 rows -->
        <com.google.android.material.button.MaterialButton
            android:id="@+id/btn_unit_swap"
            style="@style/CalculatorButtonStyle"
            android:layout_width="85dp"
            android:layout_height="165dp"
            android:layout_marginTop="9dp"
            android:background="@drawable/btn_bg_orange"
            android:contentDescription="@string/desc_swap"
            app:backgroundTint="@null"
            app:icon="@drawable/flowbite_arrow_up_down_outline"
            app:iconGravity="textStart"
            app:iconPadding="0dp"
            app:iconSize="40dp"
            app:iconTint="@android:color/white"
            app:layout_constraintBottom_toBottomOf="@id/btn_unit_dot"
            app:layout_constraintEnd_toEndOf="parent"
            app:layout_constraintStart_toEndOf="@id/gl_3"
            app:layout_constraintTop_toTopOf="@id/btn_unit_3" />

    </androidx.constraintlayout.widget.ConstraintLayout>

</androidx.constraintlayout.widget.ConstraintLayout>