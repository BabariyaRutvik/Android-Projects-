<?xml version="1.0" encoding="utf-8"?>
<androidx.constraintlayout.widget.ConstraintLayout xmlns:android="http://schemas.android.com/apk/res/android"
    xmlns:app="http://schemas.android.com/apk/res-auto"
    xmlns:tools="http://schemas.android.com/tools"
    android:id="@+id/main"
    android:layout_width="match_parent"
    android:layout_height="match_parent"
    android:background="@color/screen_background"
    tools:context=".Activity.DateCalculatorActivity">

    <!-- Custom Toolbar -->
    <com.google.android.material.appbar.AppBarLayout
        android:id="@+id/app_bar"
        android:layout_width="match_parent"
        android:layout_height="wrap_content"
        android:background="@color/screen_background"
        app:layout_constraintTop_toTopOf="parent">


        <com.google.android.material.appbar.MaterialToolbar
            android:id="@+id/date_toolbar"
            android:layout_width="match_parent"
            android:layout_height="?attr/actionBarSize"
            android:background="@color/screen_background"
            app:navigationContentDescription="@string/desc_back"
            app:navigationIcon="@drawable/ic_back"
            app:title="@string/date_calculator"
            app:titleTextAppearance="@style/ToolbarTitleStyle" />


    </com.google.android.material.appbar.AppBarLayout>

    <!-- main content -->
    <androidx.core.widget.NestedScrollView
        android:layout_width="match_parent"
        android:layout_height="0dp"
        android:fillViewport="true"
        app:layout_constraintBottom_toBottomOf="parent"
        app:layout_constraintTop_toBottomOf="@id/app_bar"
        android:id="@+id/date_scroll"
        >

        <androidx.constraintlayout.widget.ConstraintLayout
            android:id="@+id/main_scroll_container_date"
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:paddingHorizontal="16dp"
            android:paddingTop="12dp"
            android:paddingBottom="24dp">

            <!-- from box -->
            <androidx.constraintlayout.widget.ConstraintLayout
                android:id="@+id/layout_date_from"
                android:layout_width="match_parent"
                android:layout_height="80dp"
                android:background="@drawable/sl_input_bg"
                android:clickable="true"
                android:focusable="true"
                android:paddingHorizontal="16dp"
                android:paddingVertical="12dp"
                app:layout_constraintTop_toTopOf="parent">

                <TextView
                    android:id="@+id/label_date_from"
                    android:layout_width="wrap_content"
                    android:layout_height="wrap_content"
                    android:fontFamily="@font/regular"
                    android:text="@string/from"
                    android:textColor="@color/text_label_gray"
                    android:textSize="14sp"
                    app:layout_constraintStart_toStartOf="parent"
                    app:layout_constraintTop_toTopOf="parent" />

                <TextView
                    android:id="@+id/text_from"
                    android:layout_width="wrap_content"
                    android:layout_height="wrap_content"
                    android:layout_marginTop="4dp"
                    android:fontFamily="@font/regular"
                    android:text="@string/placeholder_date"
                    android:textColor="@color/input_text_color"
                    android:textSize="18sp"
                    app:layout_constraintStart_toStartOf="parent"
                    app:layout_constraintTop_toBottomOf="@id/label_date_from" />

            </androidx.constraintlayout.widget.ConstraintLayout>


            <!-- to box -->
            <androidx.constraintlayout.widget.ConstraintLayout
                android:id="@+id/layout_to_date"
                android:layout_width="match_parent"
                android:layout_height="80dp"
                android:layout_marginTop="12dp"
                android:background="@drawable/sl_input_bg"
                android:clickable="true"
                android:focusable="true"
                android:paddingHorizontal="16dp"
                android:paddingVertical="12dp"
                app:layout_constraintTop_toBottomOf="@id/layout_date_from">

                <TextView
                    android:id="@+id/label_to_date"
                    android:layout_width="wrap_content"
                    android:layout_height="wrap_content"
                    android:fontFamily="@font/regular"
                    android:text="@string/to"
                    android:textColor="@color/text_label_gray"
                    android:textSize="14sp"
                    app:layout_constraintStart_toStartOf="parent"
                    app:layout_constraintTop_toTopOf="parent" />

                <TextView
                    android:id="@+id/text_to"
                    android:layout_width="wrap_content"
                    android:layout_height="wrap_content"
                    android:layout_marginTop="4dp"
                    android:fontFamily="@font/regular"
                    android:text="@string/placeholder_date"
                    android:textColor="@color/input_text_color"
                    android:textSize="18sp"
                    app:layout_constraintStart_toStartOf="parent"
                    app:layout_constraintTop_toBottomOf="@id/label_to_date" />

            </androidx.constraintlayout.widget.ConstraintLayout>

            <!-- result section divider -->
            <androidx.constraintlayout.widget.ConstraintLayout
                android:id="@+id/result_label_container_date"
                android:layout_width="match_parent"
                android:layout_height="wrap_content"
                android:layout_marginTop="24dp"
                android:visibility="gone"
                app:layout_constraintTop_toBottomOf="@id/layout_to_date">

                <View
                    android:id="@+id/divider_left_date"
                    android:layout_width="0dp"
                    android:layout_height="1dp"
                    android:background="@color/divider_gray"
                    app:layout_constraintBottom_toBottomOf="@id/text_result_label_date"
                    app:layout_constraintEnd_toStartOf="@id/text_result_label_date"
                    app:layout_constraintStart_toStartOf="parent"
                    app:layout_constraintTop_toTopOf="@id/text_result_label_date" />

                <TextView
                    android:id="@+id/text_result_label_date"
                    android:layout_width="wrap_content"
                    android:layout_height="wrap_content"
                    android:layout_marginHorizontal="12dp"
                    android:fontFamily="@font/regular"
                    android:text="@string/result"
                    android:textColor="@color/text_primary"
                    android:textSize="16sp"
                    app:layout_constraintEnd_toEndOf="parent"
                    app:layout_constraintStart_toStartOf="parent"
                    app:layout_constraintTop_toTopOf="parent" />

                <View
                    android:id="@+id/divider_right_date"
                    android:layout_width="0dp"
                    android:layout_height="1dp"
                    android:background="@color/divider_gray"
                    app:layout_constraintBottom_toBottomOf="@id/text_result_label_date"
                    app:layout_constraintEnd_toEndOf="parent"
                    app:layout_constraintStart_toEndOf="@id/text_result_label_date"
                    app:layout_constraintTop_toTopOf="@id/text_result_label_date" />

            </androidx.constraintlayout.widget.ConstraintLayout>

            <!-- main result card -->
            <androidx.constraintlayout.widget.ConstraintLayout
                android:id="@+id/result_container_date"
                android:layout_width="match_parent"
                android:layout_height="205dp"
                android:layout_marginTop="16dp"
                android:background="@drawable/bg_result"
                android:paddingVertical="12dp"
                android:visibility="gone"
                app:layout_constraintTop_toBottomOf="@id/result_label_container_date">

                <TextView
                    android:id="@+id/text_total_difference_title"
                    android:layout_width="wrap_content"
                    android:layout_height="wrap_content"
                    android:fontFamily="@font/medium"
                    android:text="@string/total_difference"
                    android:textColor="@color/input_text_color"
                    android:textSize="20sp"
                    app:layout_constraintEnd_toEndOf="parent"
                    app:layout_constraintStart_toStartOf="parent"
                    app:layout_constraintTop_toTopOf="parent" />

                <!-- Guidelines for 3 columns -->
                <androidx.constraintlayout.widget.Guideline
                    android:id="@+id/gl_date_col_1"
                    android:layout_width="wrap_content"
                    android:layout_height="wrap_content"
                    android:orientation="vertical"
                    app:layout_constraintGuide_percent="0.333" />

                <androidx.constraintlayout.widget.Guideline
                    android:id="@+id/gl_date_col_2"
                    android:layout_width="wrap_content"
                    android:layout_height="wrap_content"
                    android:orientation="vertical"
                    app:layout_constraintGuide_percent="0.666" />

                <!-- Years -->
                <TextView
                    android:id="@+id/text_result_years"
                    android:layout_width="0dp"
                    android:layout_height="wrap_content"
                    android:layout_marginTop="12dp"
                    android:fontFamily="@font/medium"
                    android:gravity="center"
                    android:text="@string/default_zero"
                    android:textColor="@color/orange"
                    android:textSize="25sp"
                    app:layout_constraintEnd_toStartOf="@id/gl_date_col_1"
                    app:layout_constraintStart_toStartOf="parent"
                    app:layout_constraintTop_toBottomOf="@id/text_total_difference_title" />

                <TextView
                    android:id="@+id/label_result_years"
                    android:layout_width="0dp"
                    android:layout_height="wrap_content"
                    android:fontFamily="@font/regular"
                    android:gravity="center"
                    android:text="@string/years"
                    android:textColor="@color/text_label_gray"
                    android:textSize="15sp"
                    app:layout_constraintEnd_toStartOf="@id/gl_date_col_1"
                    app:layout_constraintStart_toStartOf="parent"
                    app:layout_constraintTop_toBottomOf="@id/text_result_years" />

                <!-- Vertical Divider 1 -->
                <View
                    android:id="@+id/divider_col_1"
                    android:layout_width="0.8dp"
                    android:layout_height="0dp"
                    android:layout_marginVertical="8dp"
                    android:background="@color/divider_silver"
                    app:layout_constraintBottom_toBottomOf="@id/label_result_years"
                    app:layout_constraintEnd_toEndOf="@id/gl_date_col_1"
                    app:layout_constraintStart_toStartOf="@id/gl_date_col_1"
                    app:layout_constraintTop_toTopOf="@id/text_result_years" />

                <!-- Months -->
                <TextView
                    android:id="@+id/text_result_months"
                    android:layout_width="0dp"
                    android:layout_height="wrap_content"
                    android:fontFamily="@font/medium"
                    android:gravity="center"
                    android:text="@string/default_zero"
                    android:textColor="@color/orange"
                    android:textSize="25sp"
                    app:layout_constraintEnd_toStartOf="@id/gl_date_col_2"
                    app:layout_constraintStart_toStartOf="@id/gl_date_col_1"
                    app:layout_constraintTop_toTopOf="@id/text_result_years" />

                <TextView
                    android:id="@+id/label_result_months"
                    android:layout_width="0dp"
                    android:layout_height="wrap_content"
                    android:fontFamily="@font/regular"
                    android:gravity="center"
                    android:text="@string/months"
                    android:textColor="@color/text_label_gray"
                    android:textSize="15sp"
                    app:layout_constraintEnd_toStartOf="@id/gl_date_col_2"
                    app:layout_constraintStart_toStartOf="@id/gl_date_col_1"
                    app:layout_constraintTop_toBottomOf="@id/text_result_months" />

                <!-- Vertical Divider 2 -->
                <View
                    android:id="@+id/divider_col_2"
                    android:layout_width="0.8dp"
                    android:layout_height="0dp"
                    android:layout_marginVertical="8dp"
                    android:background="@color/divider_silver"
                    app:layout_constraintBottom_toBottomOf="@id/label_result_years"
                    app:layout_constraintEnd_toEndOf="@id/gl_date_col_2"
                    app:layout_constraintStart_toStartOf="@id/gl_date_col_2"
                    app:layout_constraintTop_toTopOf="@id/text_result_years" />

                <!-- Days -->
                <TextView
                    android:id="@+id/text_result_days"
                    android:layout_width="0dp"
                    android:layout_height="wrap_content"
                    android:fontFamily="@font/medium"
                    android:gravity="center"
                    android:text="@string/default_zero"
                    android:textColor="@color/orange"
                    android:textSize="25sp"
                    app:layout_constraintEnd_toEndOf="parent"
                    app:layout_constraintStart_toStartOf="@id/gl_date_col_2"
                    app:layout_constraintTop_toTopOf="@id/text_result_years" />

                <TextView
                    android:id="@+id/label_result_days"
                    android:layout_width="0dp"
                    android:layout_height="wrap_content"
                    android:fontFamily="@font/regular"
                    android:gravity="center"
                    android:text="@string/days"
                    android:textColor="@color/text_label_gray"
                    android:textSize="15sp"
                    app:layout_constraintEnd_toEndOf="parent"
                    app:layout_constraintStart_toStartOf="@id/gl_date_col_2"
                    app:layout_constraintTop_toBottomOf="@id/text_result_days" />

                <!-- Horizontal Divider -->
                <View
                    android:id="@+id/divider_res_date_1"
                    android:layout_width="match_parent"
                    android:layout_height="0.8dp"
                    android:layout_marginHorizontal="16dp"
                    android:layout_marginTop="16dp"
                    android:background="@color/divider_silver"
                    app:layout_constraintTop_toBottomOf="@id/label_result_years" />

                <!-- From side -->
                <TextView
                    android:id="@+id/label_result_from"
                    android:layout_width="wrap_content"
                    android:layout_height="wrap_content"
                    android:layout_marginStart="24dp"
                    android:layout_marginTop="12dp"
                    android:fontFamily="@font/regular"
                    android:text="@string/from"
                    android:textColor="@color/text_label_gray"
                    android:textSize="15sp"
                    app:layout_constraintStart_toStartOf="parent"
                    app:layout_constraintTop_toBottomOf="@id/divider_res_date_1" />

                <TextView
                    android:id="@+id/text_result_from"
                    android:layout_width="wrap_content"
                    android:layout_height="wrap_content"
                    android:layout_marginTop="2dp"
                    android:fontFamily="@font/medium"
                    android:text="@string/placeholder_date"
                    android:textColor="@color/orange"
                    android:textSize="18sp"
                    app:layout_constraintStart_toStartOf="@id/label_result_from"
                    app:layout_constraintTop_toBottomOf="@id/label_result_from" />

                <!-- Bottom Vertical Divider -->
                <View
                    android:id="@+id/divider_bottom_vertical"
                    android:layout_width="0.8dp"
                    android:layout_height="0dp"
                    android:layout_marginVertical="4dp"
                    android:background="@color/divider_silver"
                    app:layout_constraintBottom_toBottomOf="@id/text_result_from"
                    app:layout_constraintEnd_toEndOf="parent"
                    app:layout_constraintStart_toStartOf="parent"
                    app:layout_constraintTop_toTopOf="@id/label_result_from" />

                <!-- To side -->
                <TextView
                    android:id="@+id/label_result_to"
                    android:layout_width="wrap_content"
                    android:layout_height="wrap_content"
                    android:layout_marginTop="12dp"
                    android:layout_marginEnd="24dp"
                    android:fontFamily="@font/regular"
                    android:text="@string/to"
                    android:textColor="@color/text_label_gray"
                    android:textSize="15sp"
                    app:layout_constraintEnd_toEndOf="parent"
                    app:layout_constraintTop_toBottomOf="@id/divider_res_date_1" />

                <TextView
                    android:id="@+id/text_result_to"
                    android:layout_width="wrap_content"
                    android:layout_height="wrap_content"
                    android:layout_marginTop="2dp"
                    android:fontFamily="@font/medium"
                    android:text="@string/placeholder_date"
                    android:textColor="@color/orange"
                    android:textSize="18sp"
                    app:layout_constraintEnd_toEndOf="@id/label_result_to"
                    app:layout_constraintTop_toBottomOf="@id/label_result_to" />

            </androidx.constraintlayout.widget.ConstraintLayout>

        </androidx.constraintlayout.widget.ConstraintLayout>

    </androidx.core.widget.NestedScrollView>

</androidx.constraintlayout.widget.ConstraintLayout>