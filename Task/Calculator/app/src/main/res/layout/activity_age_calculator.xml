<?xml version="1.0" encoding="utf-8"?>
<androidx.constraintlayout.widget.ConstraintLayout xmlns:android="http://schemas.android.com/apk/res/android"
    xmlns:app="http://schemas.android.com/apk/res-auto"
    xmlns:tools="http://schemas.android.com/tools"
    android:id="@+id/main"
    android:layout_width="match_parent"
    android:layout_height="match_parent"
    android:background="@color/screen_background"
    tools:context=".Activity.AgeCalculatorActivity">

    <!-- Custom Toolbar -->
    <com.google.android.material.appbar.AppBarLayout
        android:id="@+id/app_bar"
        android:layout_width="match_parent"
        android:layout_height="wrap_content"
        android:background="@color/screen_background"
        app:layout_constraintTop_toTopOf="parent">

        <com.google.android.material.appbar.MaterialToolbar
            android:id="@+id/age_toolbar"
            android:layout_width="match_parent"
            android:layout_height="?attr/actionBarSize"
            android:background="@color/screen_background"
            app:navigationContentDescription="@string/desc_back"
            app:navigationIcon="@drawable/ic_back"
            app:title="@string/age_calculator"
            app:titleTextAppearance="@style/ToolbarTitleStyle"
            app:contentInsetStartWithNavigation="0dp"
            app:navigationIconTint="@color/input_text_color" />

    </com.google.android.material.appbar.AppBarLayout>

    <!-- Main Scrollable Content -->
    <androidx.core.widget.NestedScrollView
        android:id="@+id/age_scroll"
        android:layout_width="match_parent"
        android:layout_height="0dp"
        android:fillViewport="true"
        app:layout_constraintBottom_toBottomOf="parent"
        app:layout_constraintTop_toBottomOf="@id/app_bar">

        <androidx.constraintlayout.widget.ConstraintLayout
            android:id="@+id/main_scroll_container"
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:paddingHorizontal="16dp"
            android:paddingTop="12dp"
            android:paddingBottom="24dp">

            <!-- Date of Birth Box -->
            <androidx.constraintlayout.widget.ConstraintLayout
                android:id="@+id/layout_dob"
                android:layout_width="match_parent"
                android:layout_height="80dp"
                android:background="@drawable/sl_input_bg"
                android:paddingHorizontal="16dp"
                android:paddingTop="12dp"
                android:paddingBottom="8dp"
                app:layout_constraintTop_toTopOf="parent">

                <TextView
                    android:id="@+id/label_dob"
                    android:layout_width="wrap_content"
                    android:layout_height="wrap_content"
                    android:fontFamily="@font/regular"
                    android:text="@string/date_of_birth"
                    android:textColor="@color/text_label_gray"
                    android:textSize="15sp"
                    app:layout_constraintStart_toStartOf="parent"
                    app:layout_constraintTop_toTopOf="parent" />

                <TextView
                    android:id="@+id/text_dob"
                    android:layout_width="wrap_content"
                    android:layout_height="wrap_content"
                    android:fontFamily="@font/regular"
                    android:text="@string/placeholder_dob"
                    android:textColor="@color/result_text_color"
                    android:textSize="18sp"
                    android:layout_marginTop="4dp"
                    app:layout_constraintBottom_toBottomOf="parent"
                    app:layout_constraintStart_toStartOf="parent"
                    app:layout_constraintTop_toBottomOf="@id/label_dob" />

            </androidx.constraintlayout.widget.ConstraintLayout>

            <!-- Today Box -->
            <androidx.constraintlayout.widget.ConstraintLayout
                android:id="@+id/layout_today"
                android:layout_width="match_parent"
                android:layout_height="80dp"
                android:layout_marginTop="12dp"
                android:background="@drawable/sl_input_bg"
                android:paddingHorizontal="16dp"
                android:paddingTop="12dp"
                android:paddingBottom="8dp"
                app:layout_constraintTop_toBottomOf="@id/layout_dob">

                <TextView
                    android:id="@+id/label_today"
                    android:layout_width="wrap_content"
                    android:layout_height="wrap_content"
                    android:fontFamily="@font/regular"
                    android:text="@string/today"
                    android:textColor="@color/text_label_gray"
                    android:textSize="15sp"
                    app:layout_constraintStart_toStartOf="parent"
                    app:layout_constraintTop_toTopOf="parent" />

                <TextView
                    android:id="@+id/text_today"
                    android:layout_width="wrap_content"
                    android:layout_height="wrap_content"
                    android:fontFamily="@font/regular"
                    android:text="@string/default_today"
                    android:textColor="@color/input_text_color"
                    android:textSize="18sp"
                    android:layout_marginTop="4dp"
                    app:layout_constraintBottom_toBottomOf="parent"
                    app:layout_constraintStart_toStartOf="parent"
                    app:layout_constraintTop_toBottomOf="@id/label_today" />

            </androidx.constraintlayout.widget.ConstraintLayout>

            <androidx.constraintlayout.widget.ConstraintLayout
                android:id="@+id/result_label_container"
                android:layout_width="match_parent"
                android:layout_height="wrap_content"
                android:layout_marginTop="24dp"
                android:visibility="gone"
                app:layout_constraintTop_toBottomOf="@id/layout_today">

                <View
                    android:id="@+id/divider_left_age"
                    android:layout_width="0dp"
                    android:layout_height="1dp"
                    android:background="@color/divider_gray"
                    app:layout_constraintBottom_toBottomOf="@id/text_result_label_age"
                    app:layout_constraintEnd_toStartOf="@id/text_result_label_age"
                    app:layout_constraintStart_toStartOf="parent"
                    app:layout_constraintTop_toTopOf="@id/text_result_label_age" />

                <TextView
                    android:id="@+id/text_result_label_age"
                    android:layout_width="wrap_content"
                    android:layout_height="wrap_content"
                    android:layout_marginHorizontal="12dp"
                    android:fontFamily="@font/regular"
                    android:text="@string/result"
                    android:textColor="@color/text_primary"
                    android:textSize="18sp"
                    app:layout_constraintEnd_toEndOf="parent"
                    app:layout_constraintStart_toStartOf="parent"
                    app:layout_constraintTop_toTopOf="parent" />

                <View
                    android:id="@+id/divider_right_age"
                    android:layout_width="0dp"
                    android:layout_height="1dp"
                    android:background="@color/divider_gray"
                    app:layout_constraintBottom_toBottomOf="@id/text_result_label_age"
                    app:layout_constraintEnd_toEndOf="parent"
                    app:layout_constraintStart_toEndOf="@id/text_result_label_age"
                    app:layout_constraintTop_toTopOf="@id/text_result_label_age" />

            </androidx.constraintlayout.widget.ConstraintLayout>

            <androidx.constraintlayout.widget.ConstraintLayout
                android:id="@+id/result_container_age"
                android:layout_width="match_parent"
                android:layout_height="145dp"
                android:layout_marginTop="16dp"
                android:background="@drawable/bg_result"
                android:padding="12dp"
                android:visibility="gone"
                app:layout_constraintTop_toBottomOf="@id/result_label_container">

                <View
                    android:id="@+id/vertical_divider"
                    android:layout_width="1dp"
                    android:layout_height="0dp"
                    android:layout_marginVertical="10dp"
                    android:background="@color/divider_silver"
                    app:layout_constraintBottom_toBottomOf="parent"
                    app:layout_constraintRight_toRightOf="parent"
                    app:layout_constraintLeft_toLeftOf="parent"
                    app:layout_constraintTop_toTopOf="parent" />

                <!-- Current Age Details -->
                <ImageView
                    android:id="@+id/img_current_age"
                    android:layout_width="40dp"
                    android:layout_height="40dp"
                    android:background="@drawable/btn_bg_age"
                    android:contentDescription="@string/desc_current_age"
                    android:padding="8dp"
                    android:src="@drawable/ic_age"
                    app:layout_constraintStart_toStartOf="parent"
                    app:layout_constraintTop_toTopOf="parent" />

                <TextView
                    android:id="@+id/lbl_current_age"
                    android:layout_width="0dp"
                    android:layout_height="wrap_content"
                    android:layout_marginTop="4dp"
                    android:fontFamily="@font/regular"
                    android:text="@string/current_age"
                    android:textColor="@color/input_text_color"
                    android:textSize="13sp"
                    android:gravity="left"
                    app:layout_constraintEnd_toStartOf="@id/vertical_divider"
                    app:layout_constraintLeft_toLeftOf="parent"
                    app:layout_constraintTop_toBottomOf="@id/img_current_age" />

                <TextView
                    android:id="@+id/text_current_age_years"
                    android:layout_width="0dp"
                    android:layout_height="wrap_content"
                    android:fontFamily="@font/medium"
                    android:text="@string/default_years"
                    android:textColor="@color/orange"
                    android:textSize="20sp"
                    android:gravity="left"
                    android:textDirection="ltr"
                    app:layout_constraintEnd_toStartOf="@id/vertical_divider"
                    app:layout_constraintLeft_toLeftOf="parent"
                    app:layout_constraintTop_toBottomOf="@id/lbl_current_age" />

                <TextView
                    android:id="@+id/text_current_age_detail"
                    android:layout_width="0dp"
                    android:layout_height="wrap_content"
                    android:fontFamily="@font/regular"
                    android:text="@string/default_age_detail"
                    android:textColor="@color/result_text_color"
                    android:textSize="13sp"
                    android:gravity="left"
                    android:textDirection="ltr"
                    app:layout_constraintEnd_toStartOf="@id/vertical_divider"
                    app:layout_constraintLeft_toLeftOf="parent"
                    app:layout_constraintTop_toBottomOf="@id/text_current_age_years" />

                <!-- Next Birthday Details -->
                <ImageView
                    android:id="@+id/img_next_birthday"
                    android:layout_width="40dp"
                    android:layout_height="40dp"
                    android:layout_marginStart="12dp"
                    android:background="@drawable/btn_bg_age"
                    android:contentDescription="@string/desc_next_birthday"
                    android:padding="8dp"
                    android:src="@drawable/proicons_cake"
                    app:layout_constraintStart_toEndOf="@id/vertical_divider"
                    app:layout_constraintTop_toTopOf="parent" />

                <TextView
                    android:id="@+id/lbl_next_birthday"
                    android:layout_width="0dp"
                    android:layout_height="wrap_content"
                    android:layout_marginStart="12dp"
                    android:layout_marginTop="4dp"
                    android:fontFamily="@font/regular"
                    android:text="@string/next_birthday"
                    android:textColor="@color/input_text_color"
                    android:textSize="13sp"
                    android:gravity="left"
                    app:layout_constraintEnd_toEndOf="parent"
                    app:layout_constraintLeft_toRightOf="@id/vertical_divider"
                    app:layout_constraintTop_toBottomOf="@id/img_next_birthday" />

                <TextView
                    android:id="@+id/text_next_birthday_day"
                    android:layout_width="0dp"
                    android:layout_height="wrap_content"
                    android:layout_marginStart="12dp"
                    android:fontFamily="@font/medium"
                    android:text="@string/monday"
                    android:textColor="@color/orange"
                    android:textSize="20sp"
                    android:gravity="left"
                    app:layout_constraintEnd_toEndOf="parent"
                    app:layout_constraintLeft_toRightOf="@id/vertical_divider"
                    app:layout_constraintTop_toBottomOf="@id/lbl_next_birthday" />

                <TextView
                    android:id="@+id/text_next_birthday_detail"
                    android:layout_width="0dp"
                    android:layout_height="wrap_content"
                    android:layout_marginStart="12dp"
                    android:fontFamily="@font/regular"
                    android:text="@string/default_birthday_detail"
                    android:textColor="@color/result_text_color"
                    android:textSize="13sp"
                    android:gravity="left"
                    android:textDirection="ltr"
                    app:layout_constraintEnd_toEndOf="parent"
                    app:layout_constraintLeft_toRightOf="@id/vertical_divider"
                    app:layout_constraintTop_toBottomOf="@id/text_next_birthday_day" />

            </androidx.constraintlayout.widget.ConstraintLayout>

        </androidx.constraintlayout.widget.ConstraintLayout>
    </androidx.core.widget.NestedScrollView>

</androidx.constraintlayout.widget.ConstraintLayout>