<?xml version="1.0" encoding="utf-8"?>
<androidx.constraintlayout.widget.ConstraintLayout
    xmlns:android="http://schemas.android.com/apk/res/android"
    xmlns:app="http://schemas.android.com/apk/res-auto"
    android:layout_width="match_parent"
    android:layout_height="wrap_content"
    android:minHeight="145dp"
    android:background="@drawable/bg_dialog_rounded"
    android:paddingStart="16dp"
    android:paddingEnd="16dp"
    android:paddingTop="20dp"
    android:paddingBottom="16dp">

    <TextView
        android:id="@+id/text_dialog_title"
        android:layout_width="wrap_content"
        android:layout_height="wrap_content"
        android:text="@string/delete_history"
        android:textSize="20sp"
        android:fontFamily="@font/regular"
        android:textColor="@color/text_primary"
        app:layout_constraintTop_toTopOf="parent"
        app:layout_constraintStart_toStartOf="parent"
        app:layout_constraintEnd_toEndOf="parent"/>

    <TextView
        android:id="@+id/text_dialog_message"
        android:layout_width="0dp"
        android:layout_height="wrap_content"
        android:layout_marginTop="12dp"
        android:layout_marginBottom="20dp"
        android:text="@string/delete_history_message"
        android:textSize="18sp"
        android:includeFontPadding="false"
        android:gravity="center"
        android:fontFamily="@font/regular"
        android:textColor="@color/text_primary"
        android:singleLine="false"
        app:layout_constraintTop_toBottomOf="@id/text_dialog_title"
        app:layout_constraintBottom_toTopOf="@id/btn_no"
        app:layout_constraintStart_toStartOf="parent"
        app:layout_constraintEnd_toEndOf="parent"/>

    <TextView
        android:id="@+id/btn_no"
        android:layout_width="0dp"
        android:layout_height="40dp"
        android:text="@string/no"
        android:textSize="18sp"
        android:gravity="center"
        android:fontFamily="@font/medium"
        android:textColor="@color/text_tertiary"
        app:layout_constraintTop_toBottomOf="@id/text_dialog_message"
        app:layout_constraintBottom_toBottomOf="parent"
        app:layout_constraintStart_toStartOf="parent"
        app:layout_constraintEnd_toStartOf="@id/btn_yes"/>

    <TextView
        android:id="@+id/btn_yes"
        android:layout_width="0dp"
        android:layout_height="40dp"
        android:text="@string/yes"
        android:textSize="18sp"
        android:gravity="center"
        android:fontFamily="@font/medium"
        android:textColor="@color/orange"
        app:layout_constraintTop_toTopOf="@id/btn_no"
        app:layout_constraintBottom_toBottomOf="@id/btn_no"
        app:layout_constraintStart_toEndOf="@id/btn_no"
        app:layout_constraintEnd_toEndOf="parent"/>

</androidx.constraintlayout.widget.ConstraintLayout>
