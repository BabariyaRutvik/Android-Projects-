<?xml version="1.0" encoding="utf-8"?>
<androidx.constraintlayout.widget.ConstraintLayout xmlns:android="http://schemas.android.com/apk/res/android"
    xmlns:app="http://schemas.android.com/apk/res-auto"
    android:layout_width="match_parent"
    android:layout_height="match_parent"
    android:paddingStart="12dp"
    android:paddingEnd="12dp">

    <!-- Vertical Guidelines -->
    <androidx.constraintlayout.widget.Guideline
        android:id="@+id/gl_v1"
        android:layout_width="wrap_content"
        android:layout_height="wrap_content"
        android:orientation="vertical"
        app:layout_constraintGuide_percent="0.25" />

    <androidx.constraintlayout.widget.Guideline
        android:id="@+id/gl_v2"
        android:layout_width="wrap_content"
        android:layout_height="wrap_content"
        android:orientation="vertical"
        app:layout_constraintGuide_percent="0.5" />

    <androidx.constraintlayout.widget.Guideline
        android:id="@+id/gl_v3"
        android:layout_width="wrap_content"
        android:layout_height="wrap_content"
        android:orientation="vertical"
        app:layout_constraintGuide_percent="0.75" />

    <!-- Horizontal Guidelines -->
    <androidx.constraintlayout.widget.Guideline
        android:id="@+id/gl_h1"
        android:layout_width="wrap_content"
        android:layout_height="wrap_content"
        android:orientation="horizontal"
        app:layout_constraintGuide_percent="0.2" />

    <androidx.constraintlayout.widget.Guideline
        android:id="@+id/gl_h2"
        android:layout_width="wrap_content"
        android:layout_height="wrap_content"
        android:orientation="horizontal"
        app:layout_constraintGuide_percent="0.4" />

    <androidx.constraintlayout.widget.Guideline
        android:id="@+id/gl_h3"
        android:layout_width="wrap_content"
        android:layout_height="wrap_content"
        android:orientation="horizontal"
        app:layout_constraintGuide_percent="0.6" />

    <androidx.constraintlayout.widget.Guideline
        android:id="@+id/gl_h4"
        android:layout_width="wrap_content"
        android:layout_height="wrap_content"
        android:orientation="horizontal"
        app:layout_constraintGuide_percent="0.8" />

    <!-- Row 1 -->
    <com.google.android.material.button.MaterialButton
        android:id="@+id/btn_ac"
        style="@style/StandardButtonStyle"
        android:layout_margin="5dp"
        android:fontFamily="@font/regular"
        android:text="AC"
        android:textColor="@color/red_dark"
        android:textSize="26sp"
        app:backgroundTint="@color/red_light"
        app:layout_constraintBottom_toTopOf="@+id/gl_h1"
        app:layout_constraintEnd_toStartOf="@+id/gl_v1"
        app:layout_constraintStart_toStartOf="parent"
        app:layout_constraintTop_toTopOf="parent" />


    <com.google.android.material.button.MaterialButton
        android:id="@+id/btn_plus_minus"
        style="@style/StandardButtonStyle"
        android:layout_margin="5dp"
        app:backgroundTint="@color/operation_button_color"
        android:fontFamily="@font/regular"
        app:icon="@drawable/mynaui_percentage"
        app:iconGravity="textStart"
        app:iconPadding="0dp"
        app:iconSize="34dp"
        app:iconTint="@color/input_text_color"
        app:layout_constraintBottom_toTopOf="@+id/gl_h1"
        app:layout_constraintEnd_toStartOf="@+id/gl_v2"
        app:layout_constraintStart_toEndOf="@+id/gl_v1"
        app:layout_constraintTop_toTopOf="parent" />

    <com.google.android.material.button.MaterialButton
        android:id="@+id/btn_percent"
        style="@style/StandardButtonStyle"
        android:layout_margin="5dp"
        app:backgroundTint="@color/operation_button_color"
        android:fontFamily="@font/regular"
        app:icon="@drawable/ic_percentage"
        app:iconGravity="textStart"
        app:iconPadding="0dp"
        app:iconSize="34dp"
        app:iconTint="@color/input_text_color"
        app:layout_constraintBottom_toTopOf="@+id/gl_h1"
        app:layout_constraintEnd_toStartOf="@+id/gl_v3"
        app:layout_constraintStart_toEndOf="@+id/gl_v2"
        app:layout_constraintTop_toTopOf="parent" />

    <com.google.android.material.button.MaterialButton
        android:id="@+id/btn_divide"
        style="@style/StandardButtonStyle"
        android:layout_margin="5dp"
        app:backgroundTint="@color/operation_button_color"
        android:fontFamily="@font/regular"
        app:icon="@drawable/ic_devide"
        app:iconGravity="textStart"
        app:iconPadding="0dp"
        app:iconSize="34dp"
        app:iconTint="@color/input_text_color"
        app:layout_constraintBottom_toTopOf="@+id/gl_h1"
        app:layout_constraintEnd_toEndOf="parent"
        app:layout_constraintStart_toEndOf="@+id/gl_v3"
        app:layout_constraintTop_toTopOf="parent" />

    <!-- Row 2 -->
    <com.google.android.material.button.MaterialButton
        android:id="@+id/btn_7"
        style="@style/StandardButtonStyle"
        android:layout_margin="5dp"
        app:backgroundTint="@color/white"
        android:fontFamily="@font/regular"
        android:text="7"
        android:textColor="@color/input_text_color"
        android:textSize="32sp"
        app:layout_constraintBottom_toTopOf="@+id/gl_h2"
        app:layout_constraintEnd_toStartOf="@+id/gl_v1"
        app:layout_constraintStart_toStartOf="parent"
        app:layout_constraintTop_toBottomOf="@+id/gl_h1" />

    <com.google.android.material.button.MaterialButton
        android:id="@+id/btn_8"
        style="@style/StandardButtonStyle"
        android:layout_margin="5dp"
        app:backgroundTint="@color/white"
        android:fontFamily="@font/regular"
        android:text="8"
        android:textColor="@color/input_text_color"
        android:textSize="32sp"
        app:layout_constraintBottom_toTopOf="@+id/gl_h2"
        app:layout_constraintEnd_toStartOf="@+id/gl_v2"
        app:layout_constraintStart_toEndOf="@+id/gl_v1"
        app:layout_constraintTop_toBottomOf="@+id/gl_h1" />

    <com.google.android.material.button.MaterialButton
        android:id="@+id/btn_9"
        style="@style/StandardButtonStyle"
        android:layout_margin="5dp"
        app:backgroundTint="@color/white"
        android:fontFamily="@font/regular"
        android:text="9"
        android:textColor="@color/input_text_color"
        android:textSize="32sp"
        app:layout_constraintBottom_toTopOf="@+id/gl_h2"
        app:layout_constraintEnd_toStartOf="@+id/gl_v3"
        app:layout_constraintStart_toEndOf="@+id/gl_v2"
        app:layout_constraintTop_toBottomOf="@+id/gl_h1" />

    <com.google.android.material.button.MaterialButton
        android:id="@+id/btn_multiply"
        style="@style/StandardButtonStyle"
        android:layout_margin="5dp"
        app:backgroundTint="@color/operation_button_color"
        android:fontFamily="@font/regular"
        app:icon="@drawable/ic_multiply"
        app:iconGravity="textStart"
        app:iconPadding="0dp"
        app:iconSize="34dp"
        app:iconTint="@color/input_text_color"
        app:layout_constraintBottom_toTopOf="@+id/gl_h2"
        app:layout_constraintEnd_toEndOf="parent"
        app:layout_constraintStart_toEndOf="@+id/gl_v3"
        app:layout_constraintTop_toBottomOf="@+id/gl_h1" />

    <!-- Row 3 -->
    <com.google.android.material.button.MaterialButton
        android:id="@+id/btn_4"
        style="@style/StandardButtonStyle"
        android:layout_margin="5dp"
        app:backgroundTint="@color/white"
        android:fontFamily="@font/regular"
        android:text="4"
        android:textColor="@color/input_text_color"
        android:textSize="32sp"
        app:layout_constraintBottom_toTopOf="@+id/gl_h3"
        app:layout_constraintEnd_toStartOf="@+id/gl_v1"
        app:layout_constraintStart_toStartOf="parent"
        app:layout_constraintTop_toBottomOf="@+id/gl_h2" />

    <com.google.android.material.button.MaterialButton
        android:id="@+id/btn_5"
        style="@style/StandardButtonStyle"
        android:layout_margin="5dp"
        app:backgroundTint="@color/white"
        android:fontFamily="@font/regular"
        android:text="5"
        android:textColor="@color/input_text_color"
        android:textSize="32sp"
        app:layout_constraintBottom_toTopOf="@+id/gl_h3"
        app:layout_constraintEnd_toStartOf="@+id/gl_v2"
        app:layout_constraintStart_toEndOf="@+id/gl_v1"
        app:layout_constraintTop_toBottomOf="@+id/gl_h2" />

    <com.google.android.material.button.MaterialButton
        android:id="@+id/btn_6"
        style="@style/StandardButtonStyle"
        android:layout_margin="5dp"
        app:backgroundTint="@color/white"
        android:fontFamily="@font/regular"
        android:text="6"
        android:textColor="@color/input_text_color"
        android:textSize="32sp"
        app:layout_constraintBottom_toTopOf="@+id/gl_h3"
        app:layout_constraintEnd_toStartOf="@+id/gl_v3"
        app:layout_constraintStart_toEndOf="@+id/gl_v2"
        app:layout_constraintTop_toBottomOf="@+id/gl_h2" />

    <com.google.android.material.button.MaterialButton
        android:id="@+id/btn_minus"
        style="@style/StandardButtonStyle"
        android:layout_margin="5dp"
        app:backgroundTint="@color/operation_button_color"
        android:fontFamily="@font/regular"
        app:icon="@drawable/ic_basline_minus"
        app:iconTint="@color/input_text_color"
        app:iconGravity="textStart"
        app:iconPadding="0dp"
        app:iconSize="34dp"
        app:layout_constraintBottom_toTopOf="@+id/gl_h3"
        app:layout_constraintEnd_toEndOf="parent"
        app:layout_constraintStart_toEndOf="@+id/gl_v3"
        app:layout_constraintTop_toBottomOf="@+id/gl_h2" />

    <!-- Row 4 -->
    <com.google.android.material.button.MaterialButton
        android:id="@+id/btn_1"
        style="@style/StandardButtonStyle"
        android:layout_margin="5dp"
        app:backgroundTint="@color/white"
        android:fontFamily="@font/regular"
        android:text="1"
        android:textColor="@color/input_text_color"
        android:textSize="32sp"
        app:layout_constraintBottom_toTopOf="@+id/gl_h4"
        app:layout_constraintEnd_toStartOf="@+id/gl_v1"
        app:layout_constraintStart_toStartOf="parent"
        app:layout_constraintTop_toBottomOf="@+id/gl_h3" />

    <com.google.android.material.button.MaterialButton
        android:id="@+id/btn_2"
        style="@style/StandardButtonStyle"
        android:layout_margin="5dp"
        app:backgroundTint="@color/white"
        android:fontFamily="@font/regular"
        android:text="2"
        android:textColor="@color/input_text_color"
        android:textSize="32sp"
        app:layout_constraintBottom_toTopOf="@+id/gl_h4"
        app:layout_constraintEnd_toStartOf="@+id/gl_v2"
        app:layout_constraintStart_toEndOf="@+id/gl_v1"
        app:layout_constraintTop_toBottomOf="@+id/gl_h3" />

    <com.google.android.material.button.MaterialButton
        android:id="@+id/btn_3"
        style="@style/StandardButtonStyle"
        android:layout_margin="5dp"
        app:backgroundTint="@color/white"
        android:fontFamily="@font/regular"
        android:text="3"
        android:textColor="@color/input_text_color"
        android:textSize="32sp"
        app:layout_constraintBottom_toTopOf="@+id/gl_h4"
        app:layout_constraintEnd_toStartOf="@+id/gl_v3"
        app:layout_constraintStart_toEndOf="@+id/gl_v2"
        app:layout_constraintTop_toBottomOf="@+id/gl_h3" />

    <com.google.android.material.button.MaterialButton
        android:id="@+id/btn_plus"
        style="@style/StandardButtonStyle"
        android:layout_margin="5dp"
        app:backgroundTint="@color/operation_button_color"
        android:fontFamily="@font/regular"
        app:icon="@drawable/ic_plus"
        app:iconGravity="textStart"
        app:iconPadding="0dp"
        app:iconSize="34dp"
        app:iconTint="@color/input_text_color"
        app:layout_constraintBottom_toTopOf="@+id/gl_h4"
        app:layout_constraintEnd_toEndOf="parent"
        app:layout_constraintStart_toEndOf="@+id/gl_v3"
        app:layout_constraintTop_toBottomOf="@+id/gl_h3" />

    <!-- Row 5 -->
    <com.google.android.material.button.MaterialButton
        android:id="@+id/btn_00"
        style="@style/StandardButtonStyle"
        android:layout_margin="5dp"
        app:backgroundTint="@color/white"
        android:fontFamily="@font/regular"
        android:text="00"
        android:textAllCaps="false"
        android:textColor="@color/input_text_color"
        android:textSize="32sp"
        app:layout_constraintBottom_toBottomOf="parent"
        app:layout_constraintEnd_toStartOf="@+id/gl_v1"
        app:layout_constraintStart_toStartOf="parent"
        app:layout_constraintTop_toBottomOf="@+id/gl_h4" />

    <com.google.android.material.button.MaterialButton
        android:id="@+id/btn_0"
        style="@style/StandardButtonStyle"
        android:layout_margin="5dp"
        app:backgroundTint="@color/white"
        android:fontFamily="@font/regular"
        android:text="0"
        android:textColor="@color/input_text_color"
        android:textSize="32sp"
        app:layout_constraintBottom_toBottomOf="parent"
        app:layout_constraintEnd_toStartOf="@+id/gl_v2"
        app:layout_constraintStart_toEndOf="@+id/gl_v1"
        app:layout_constraintTop_toBottomOf="@+id/gl_h4" />

    <com.google.android.material.button.MaterialButton
        android:id="@+id/btn_dot"
        style="@style/StandardButtonStyle"
        android:layout_margin="5dp"
        app:backgroundTint="@color/white"
        android:fontFamily="@font/regular"
        android:text="."
        android:textColor="@color/input_text_color"
        android:textSize="32sp"
        app:layout_constraintBottom_toBottomOf="parent"
        app:layout_constraintEnd_toStartOf="@+id/gl_v3"
        app:layout_constraintStart_toEndOf="@+id/gl_v2"
        app:layout_constraintTop_toBottomOf="@+id/gl_h4" />

    <com.google.android.material.button.MaterialButton
        android:id="@+id/id_equals"
        style="@style/StandardButtonStyle"
        android:layout_margin="5dp"
        app:backgroundTint="@color/orange"
        android:fontFamily="@font/regular"
        app:icon="@drawable/ic_equal_to"
        app:iconGravity="textStart"
        app:iconPadding="0dp"
        app:iconSize="34dp"
        app:iconTint="@android:color/white"
        app:layout_constraintBottom_toBottomOf="parent"
        app:layout_constraintEnd_toEndOf="parent"
        app:layout_constraintStart_toEndOf="@+id/gl_v3"
        app:layout_constraintTop_toBottomOf="@+id/gl_h4" />

</androidx.constraintlayout.widget.ConstraintLayout>
