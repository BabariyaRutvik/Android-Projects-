<?xml version="1.0" encoding="utf-8"?>
<androidx.constraintlayout.widget.ConstraintLayout xmlns:android="http://schemas.android.com/apk/res/android"
    xmlns:app="http://schemas.android.com/apk/res-auto"
    xmlns:tools="http://schemas.android.com/tools"
    android:id="@+id/main"
    android:layout_width="match_parent"
    android:layout_height="match_parent"
    android:background="@color/screen_background"
    tools:context=".Activity.SIPCalculatorActivity">

    <!-- Custom Toolbar -->
    <com.google.android.material.appbar.AppBarLayout
        android:id="@+id/app_bar"
        android:layout_width="match_parent"
        android:layout_height="wrap_content"
        android:background="@color/screen_background"
        app:layout_constraintTop_toTopOf="parent">

        <com.google.android.material.appbar.MaterialToolbar
            android:id="@+id/toolbar"
            android:layout_width="match_parent"
            android:layout_height="?attr/actionBarSize"
            android:background="@color/screen_background"
            app:navigationIcon="@drawable/ic_back"
            app:navigationContentDescription="@string/desc_back"
            app:title="@string/sip_calculator"
            app:titleTextAppearance="@style/ToolbarTitleStyle"
            app:contentInsetStartWithNavigation="0dp"
            app:navigationIconTint="@color/input_text_color" />

    </com.google.android.material.appbar.AppBarLayout>


    <!-- Main Scrollable Content -->
    <androidx.core.widget.NestedScrollView
        android:id="@+id/main_scroll"
        android:layout_width="match_parent"
        android:layout_height="0dp"
        android:fillViewport="true"
        app:layout_constraintBottom_toTopOf="@id/keypad"
        app:layout_constraintTop_toBottomOf="@id/app_bar">

        <androidx.constraintlayout.widget.ConstraintLayout
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:paddingTop="4dp"
            android:paddingBottom="12dp">

            <!-- input Section -->
            <androidx.constraintlayout.widget.ConstraintLayout
                android:id="@+id/input_container"
                android:layout_width="match_parent"
                android:layout_height="wrap_content"
                android:paddingHorizontal="4dp"
                app:layout_constraintTop_toTopOf="parent">

                <!-- Monthly SIP Amount -->
                <androidx.constraintlayout.widget.ConstraintLayout
                    android:id="@+id/layout_sip_amount"
                    android:layout_width="match_parent"
                    android:layout_height="80dp"
                    android:background="@drawable/sl_input_bg"
                    android:paddingHorizontal="16dp"
                    android:paddingTop="12dp"
                    android:paddingBottom="8dp"
                    app:layout_constraintTop_toTopOf="parent">

                    <TextView
                        android:id="@+id/label_sip_amount"
                        android:layout_width="wrap_content"
                        android:layout_height="wrap_content"
                        android:fontFamily="@font/regular"
                        android:text="@string/monthly_sip_amount"
                        android:textColor="@color/text_label_gray"
                        android:textSize="15sp"
                        app:layout_constraintStart_toStartOf="parent"
                        app:layout_constraintTop_toTopOf="parent" />

                    <EditText
                        android:id="@+id/text_sip_amount"
                        android:layout_width="0dp"
                        android:layout_height="0dp"
                        android:background="@android:color/transparent"
                        android:cursorVisible="true"
                        android:focusable="true"
                        android:focusableInTouchMode="true"
                        android:fontFamily="@font/regular"
                        android:hint="@string/add_amount"
                        android:inputType="numberDecimal"
                        android:digits="0123456789."
                        android:textColor="@color/input_text_color"
                        android:textColorHint="@color/result_text_color"
                        android:textCursorDrawable="@drawable/orange_cursor"
                        android:textSize="18sp"
                        android:minHeight="48dp"
                        android:importantForAutofill="no"
                        android:paddingVertical="0dp"
                        android:gravity="bottom|left"
                        android:textDirection="locale"
                        android:layout_marginTop="4dp"
                        app:layout_constraintBottom_toBottomOf="parent"
                        app:layout_constraintEnd_toEndOf="parent"
                        app:layout_constraintStart_toStartOf="parent"
                        app:layout_constraintTop_toBottomOf="@id/label_sip_amount" />

                </androidx.constraintlayout.widget.ConstraintLayout>

                <!-- Rate -->
                <androidx.constraintlayout.widget.ConstraintLayout
                    android:id="@+id/layout_rate"
                    android:layout_width="match_parent"
                    android:layout_height="80dp"
                    android:layout_marginTop="12dp"
                    android:background="@drawable/sl_input_bg"
                    android:paddingHorizontal="16dp"
                    android:paddingTop="12dp"
                    android:paddingBottom="8dp"
                    app:layout_constraintTop_toBottomOf="@id/layout_sip_amount">

                    <TextView
                        android:id="@+id/label_rate"
                        android:layout_width="wrap_content"
                        android:layout_height="wrap_content"
                        android:fontFamily="@font/regular"
                        android:text="@string/rate_percentage"
                        android:textColor="@color/text_label_gray"
                        android:textSize="15sp"
                        app:layout_constraintStart_toStartOf="parent"
                        app:layout_constraintTop_toTopOf="parent" />

                    <EditText
                        android:id="@+id/text_rate"
                        android:layout_width="0dp"
                        android:layout_height="0dp"
                        android:background="@android:color/transparent"
                        android:cursorVisible="true"
                        android:focusable="true"
                        android:focusableInTouchMode="true"
                        android:fontFamily="@font/regular"
                        android:hint="@string/add_rate"
                        android:inputType="numberDecimal"
                        android:digits="0123456789."
                        android:textColor="@color/input_text_color"
                        android:textColorHint="@color/result_text_color"
                        android:textCursorDrawable="@drawable/orange_cursor"
                        android:textSize="18sp"
                        android:minHeight="48dp"
                        android:importantForAutofill="no"
                        android:paddingVertical="0dp"
                        android:gravity="bottom|left"
                        android:textDirection="locale"
                        android:layout_marginTop="4dp"
                        app:layout_constraintBottom_toBottomOf="parent"
                        app:layout_constraintEnd_toEndOf="parent"
                        app:layout_constraintStart_toStartOf="parent"
                        app:layout_constraintTop_toBottomOf="@id/label_rate" />

                </androidx.constraintlayout.widget.ConstraintLayout>

                <!-- Investment Period -->
                <androidx.constraintlayout.widget.ConstraintLayout
                    android:id="@+id/layout_period"
                    android:layout_width="match_parent"
                    android:layout_height="80dp"
                    android:layout_marginTop="12dp"
                    android:background="@drawable/sl_input_bg"
                    android:paddingHorizontal="16dp"
                    android:paddingTop="12dp"
                    android:paddingBottom="8dp"
                    app:layout_constraintTop_toBottomOf="@id/layout_rate">

                    <TextView
                        android:id="@+id/label_period"
                        android:layout_width="wrap_content"
                        android:layout_height="wrap_content"
                        android:fontFamily="@font/regular"
                        android:text="@string/investment_period"
                        android:textColor="@color/text_label_gray"
                        android:textSize="15sp"
                        app:layout_constraintStart_toStartOf="parent"
                        app:layout_constraintTop_toTopOf="parent" />

                    <TextView
                        android:id="@+id/text_period"
                        android:layout_width="wrap_content"
                        android:layout_height="wrap_content"
                        android:fontFamily="@font/regular"
                        android:text="@string/default_period"
                        android:textColor="@color/input_text_color"
                        android:textSize="18sp"
                        android:layout_marginTop="4dp"
                        app:layout_constraintBottom_toBottomOf="parent"
                        app:layout_constraintStart_toStartOf="parent"
                        app:layout_constraintTop_toBottomOf="@id/label_period" />

                </androidx.constraintlayout.widget.ConstraintLayout>

            </androidx.constraintlayout.widget.ConstraintLayout>

            <androidx.constraintlayout.widget.ConstraintLayout
                android:id="@+id/result_container"
                android:layout_width="match_parent"
                android:layout_height="wrap_content"
                android:layout_marginTop="16dp"
                android:paddingHorizontal="8dp"
                android:visibility="gone"
                app:layout_constraintTop_toBottomOf="@id/input_container">

                <View
                    android:id="@+id/divider_left"
                    android:layout_width="0dp"
                    android:layout_height="1dp"
                    android:background="@color/divider_gray"
                    app:layout_constraintBottom_toBottomOf="@id/text_result_label"
                    app:layout_constraintEnd_toStartOf="@id/text_result_label"
                    app:layout_constraintStart_toStartOf="parent"
                    app:layout_constraintTop_toTopOf="@id/text_result_label" />

                <TextView
                    android:id="@+id/text_result_label"
                    android:layout_width="wrap_content"
                    android:layout_height="wrap_content"
                    android:layout_marginHorizontal="12dp"
                    android:fontFamily="@font/regular"
                    android:text="@string/result"
                    android:textColor="@color/text_primary"
                    android:textSize="18sp"
                    app:layout_constraintEnd_toEndOf="parent"
                    app:layout_constraintStart_toStartOf="parent"
                    app:layout_constraintTop_toTopOf="parent" />

                <View
                    android:id="@+id/divider_right"
                    android:layout_width="0dp"
                    android:layout_height="1dp"
                    android:background="@color/divider_gray"
                    app:layout_constraintBottom_toBottomOf="@id/text_result_label"
                    app:layout_constraintEnd_toEndOf="parent"
                    app:layout_constraintStart_toEndOf="@id/text_result_label"
                    app:layout_constraintTop_toTopOf="@id/text_result_label" />

                <androidx.constraintlayout.widget.ConstraintLayout
                    android:layout_width="match_parent"
                    android:layout_height="wrap_content"
                    android:minHeight="217dp"
                    android:layout_marginTop="16dp"
                    android:background="@drawable/bg_result"
                    android:paddingHorizontal="15dp"
                    android:paddingVertical="18dp"
                    android:layoutDirection="ltr"
                    app:layout_constraintTop_toBottomOf="@id/text_result_label">

                    <TextView
                        android:id="@+id/lbl_expected_amount"
                        android:layout_width="wrap_content"
                        android:layout_height="wrap_content"
                        android:fontFamily="@font/regular"
                        android:text="@string/expected_amount"
                        android:textColor="@color/text_label_gray"
                        android:textSize="15sp"
                        app:layout_constraintStart_toStartOf="parent"
                        app:layout_constraintTop_toTopOf="parent" />

                    <TextView
                        android:id="@+id/text_expected_amount"
                        android:layout_width="wrap_content"
                        android:layout_height="wrap_content"
                        android:layout_marginTop="4dp"
                        android:fontFamily="@font/medium"
                        android:text="@string/currency_zero"
                        android:textColor="@color/orange"
                        android:textSize="35sp"
                        android:textDirection="ltr"
                        app:layout_constraintStart_toStartOf="parent"
                        app:layout_constraintTop_toBottomOf="@id/lbl_expected_amount" />

                    <View
                        android:id="@+id/divider_res_1"
                        android:layout_width="match_parent"
                        android:layout_height="1dp"
                        android:layout_marginTop="16dp"
                        android:background="@color/divider_silver"
                        app:layout_constraintTop_toBottomOf="@id/text_expected_amount" />

                    <TextView
                        android:id="@+id/lbl_amount_invested"
                        android:layout_width="wrap_content"
                        android:layout_height="wrap_content"
                        android:layout_marginTop="14dp"
                        android:fontFamily="@font/regular"
                        android:text="@string/amount_invested"
                        android:textColor="@color/input_text_color"
                        android:textSize="15sp"
                        app:layout_constraintStart_toStartOf="parent"
                        app:layout_constraintTop_toBottomOf="@id/divider_res_1" />

                    <TextView
                        android:id="@+id/text_amount_invested"
                        android:layout_width="wrap_content"
                        android:layout_height="wrap_content"
                        android:fontFamily="@font/medium"
                        android:text="@string/currency_zero"
                        android:textColor="@color/orange"
                        android:textSize="16sp"
                        android:textDirection="ltr"
                        app:layout_constraintBottom_toBottomOf="@id/lbl_amount_invested"
                        app:layout_constraintEnd_toEndOf="parent"
                        app:layout_constraintTop_toTopOf="@id/lbl_amount_invested" />

                    <View
                        android:id="@+id/divider_res_2"
                        android:layout_width="match_parent"
                        android:layout_height="1dp"
                        android:layout_marginTop="14dp"
                        android:background="@color/divider_silver"
                        app:layout_constraintTop_toBottomOf="@id/lbl_amount_invested" />

                    <TextView
                        android:id="@+id/lbl_wealth_gain"
                        android:layout_width="wrap_content"
                        android:layout_height="wrap_content"
                        android:layout_marginTop="14dp"
                        android:fontFamily="@font/regular"
                        android:text="@string/wealth_gain"
                        android:textColor="@color/input_text_color"
                        android:textSize="15sp"
                        app:layout_constraintStart_toStartOf="parent"
                        app:layout_constraintTop_toBottomOf="@id/divider_res_2" />

                    <TextView
                        android:id="@+id/text_wealth_gain"
                        android:layout_width="wrap_content"
                        android:layout_height="wrap_content"
                        android:fontFamily="@font/medium"
                        android:text="@string/currency_zero"
                        android:textColor="@color/orange"
                        android:textSize="16sp"
                        android:textDirection="ltr"
                        app:layout_constraintBottom_toBottomOf="@id/lbl_wealth_gain"
                        app:layout_constraintEnd_toEndOf="parent"
                        app:layout_constraintTop_toTopOf="@id/lbl_wealth_gain" />

                    <View
                        android:id="@+id/divider_res_3"
                        android:layout_width="match_parent"
                        android:layout_height="1dp"
                        android:layout_marginTop="14dp"
                        android:background="@color/divider_silver"
                        app:layout_constraintTop_toBottomOf="@id/lbl_wealth_gain" />

                    <TextView
                        android:id="@+id/lbl_investment_growth"
                        android:layout_width="wrap_content"
                        android:layout_height="wrap_content"
                        android:layout_marginTop="14dp"
                        android:fontFamily="@font/regular"
                        android:text="@string/investment_growth"
                        android:textColor="@color/input_text_color"
                        android:textSize="15sp"
                        app:layout_constraintStart_toStartOf="parent"
                        app:layout_constraintTop_toBottomOf="@id/divider_res_3" />

                    <TextView
                        android:id="@+id/text_investment_growth"
                        android:layout_width="wrap_content"
                        android:layout_height="wrap_content"
                        android:fontFamily="@font/medium"
                        android:text="@string/times_growth"
                        android:textColor="@color/orange"
                        android:textSize="16sp"
                        android:textDirection="ltr"
                        app:layout_constraintBottom_toBottomOf="@id/lbl_investment_growth"
                        app:layout_constraintEnd_toEndOf="parent"
                        app:layout_constraintTop_toTopOf="@id/lbl_investment_growth" />

                </androidx.constraintlayout.widget.ConstraintLayout>

            </androidx.constraintlayout.widget.ConstraintLayout>

        </androidx.constraintlayout.widget.ConstraintLayout>
    </androidx.core.widget.NestedScrollView>

    <!-- keypad Section -->
    <androidx.constraintlayout.widget.ConstraintLayout
        android:id="@+id/keypad"
        android:layout_width="match_parent"
        android:layout_height="wrap_content"
        android:layout_marginTop="8dp"
        android:paddingTop="4dp"
        android:paddingLeft="6dp"
        android:paddingRight="6dp"
        android:paddingBottom="6dp"
        android:layoutDirection="ltr"
        app:layout_constraintBottom_toBottomOf="parent">

        <androidx.constraintlayout.widget.Guideline
            android:id="@+id/gl_1"
            android:layout_width="wrap_content"
            android:layout_height="wrap_content"
            android:orientation="vertical"
            app:layout_constraintGuide_percent="0.25" />

        <androidx.constraintlayout.widget.Guideline
            android:id="@+id/gl_2"
            android:layout_width="wrap_content"
            android:layout_height="wrap_content"
            android:orientation="vertical"
            app:layout_constraintGuide_percent="0.5" />

        <androidx.constraintlayout.widget.Guideline
            android:id="@+id/gl_3"
            android:layout_width="wrap_content"
            android:layout_height="wrap_content"
            android:orientation="vertical"
            app:layout_constraintGuide_percent="0.75" />

        <!-- Row 1 -->
        <com.google.android.material.button.MaterialButton
            android:id="@+id/btn_7"
            style="@style/StandardButtonStyle"
            android:text="@string/btn_7"
            android:textColor="@color/input_text_color"
            android:textSize="32sp"
            android:fontFamily="@font/regular"
            android:background="@drawable/btn_bg_white"
            app:backgroundTint="@null"
            app:layout_constraintLeft_toLeftOf="parent"
            app:layout_constraintRight_toLeftOf="@id/gl_1"
            app:layout_constraintTop_toTopOf="parent" />

        <com.google.android.material.button.MaterialButton
            android:id="@+id/btn_8"
            style="@style/StandardButtonStyle"
            android:text="@string/btn_8"
            android:textColor="@color/input_text_color"
            android:textSize="32sp"
            android:fontFamily="@font/regular"
            android:background="@drawable/btn_bg_white"
            app:backgroundTint="@null"
            app:layout_constraintLeft_toRightOf="@id/gl_1"
            app:layout_constraintRight_toLeftOf="@id/gl_2"
            app:layout_constraintTop_toTopOf="parent" />

        <com.google.android.material.button.MaterialButton
            android:id="@+id/btn_9"
            style="@style/CalculatorButtonStyle"
            android:text="@string/btn_9"
            android:textColor="@color/input_text_color"
            android:textSize="32sp"
            android:fontFamily="@font/regular"
            android:background="@drawable/btn_bg_white"
            app:backgroundTint="@null"
            app:layout_constraintLeft_toRightOf="@id/gl_2"
            app:layout_constraintRight_toLeftOf="@id/gl_3"
            app:layout_constraintTop_toTopOf="parent" />

        <com.google.android.material.button.MaterialButton
            android:id="@+id/btn_ac"
            style="@style/CalculatorButtonStyle"
            android:text="@string/btn_ac"
            android:textColor="@color/red_dark"
            android:textSize="26sp"
            android:fontFamily="@font/regular"
            android:background="@drawable/btn_bg_light_red"
            app:backgroundTint="@null"
            app:layout_constraintLeft_toRightOf="@id/gl_3"
            app:layout_constraintRight_toRightOf="parent"
            app:layout_constraintTop_toTopOf="parent" />

        <!-- Row 2 -->
        <com.google.android.material.button.MaterialButton
            android:id="@+id/btn_4"
            style="@style/CalculatorButtonStyle"
            android:layout_marginTop="9dp"
            android:text="@string/btn_4"
            android:textColor="@color/input_text_color"
            android:textSize="32sp"
            android:fontFamily="@font/regular"
            android:background="@drawable/btn_bg_white"
            app:backgroundTint="@null"
            app:layout_constraintLeft_toLeftOf="parent"
            app:layout_constraintRight_toLeftOf="@id/gl_1"
            app:layout_constraintTop_toBottomOf="@id/btn_7" />

        <com.google.android.material.button.MaterialButton
            android:id="@+id/btn_5"
            style="@style/CalculatorButtonStyle"
            android:layout_marginTop="9dp"
            android:text="@string/btn_5"
            android:textColor="@color/input_text_color"
            android:textSize="32sp"
            android:fontFamily="@font/regular"
            android:background="@drawable/btn_bg_white"
            app:backgroundTint="@null"
            app:layout_constraintLeft_toRightOf="@id/gl_1"
            app:layout_constraintRight_toLeftOf="@id/gl_2"
            app:layout_constraintTop_toBottomOf="@id/btn_8" />

        <com.google.android.material.button.MaterialButton
            android:id="@+id/btn_6"
            style="@style/CalculatorButtonStyle"
            android:layout_marginTop="9dp"
            android:text="@string/btn_6"
            android:textColor="@color/input_text_color"
            android:textSize="32sp"
            android:fontFamily="@font/regular"
            android:background="@drawable/btn_bg_white"
            app:backgroundTint="@null"
            app:layout_constraintLeft_toRightOf="@id/gl_2"
            app:layout_constraintRight_toLeftOf="@id/gl_3"
            app:layout_constraintTop_toBottomOf="@id/btn_9" />

        <com.google.android.material.button.MaterialButton
            android:id="@+id/btn_backspace"
            style="@style/CalculatorButtonStyle"
            android:layout_marginTop="9dp"
            android:background="@drawable/btn_bg_gray"
            app:backgroundTint="@null"
            app:icon="@drawable/backspace_calculator_mode"
            app:iconGravity="textStart"
            app:iconPadding="0dp"
            app:iconSize="34dp"
            android:foreground="?attr/selectableItemBackgroundBorderless"
            android:foregroundGravity="center"
            app:iconTint="@color/input_text_color"
            android:contentDescription="@string/desc_backspace"
            app:layout_constraintLeft_toRightOf="@id/gl_3"
            app:layout_constraintRight_toRightOf="parent"
            app:layout_constraintTop_toBottomOf="@id/btn_ac" />

        <!-- Row 3 -->
        <com.google.android.material.button.MaterialButton
            android:id="@+id/btn_1"
            style="@style/CalculatorButtonStyle"
            android:layout_marginTop="9dp"
            android:text="@string/btn_1"
            android:textColor="@color/input_text_color"
            android:textSize="32sp"
            android:fontFamily="@font/regular"
            android:background="@drawable/btn_bg_white"
            app:backgroundTint="@null"
            app:layout_constraintLeft_toLeftOf="parent"
            app:layout_constraintRight_toLeftOf="@id/gl_1"
            app:layout_constraintTop_toBottomOf="@id/btn_4" />

        <com.google.android.material.button.MaterialButton
            android:id="@+id/btn_2"
            style="@style/CalculatorButtonStyle"
            android:layout_marginTop="9dp"
            android:text="@string/btn_2"
            android:textColor="@color/input_text_color"
            android:textSize="32sp"
            android:fontFamily="@font/regular"
            android:background="@drawable/btn_bg_white"
            app:backgroundTint="@null"
            app:layout_constraintLeft_toRightOf="@id/gl_1"
            app:layout_constraintRight_toLeftOf="@id/gl_2"
            app:layout_constraintTop_toBottomOf="@id/btn_5" />

        <com.google.android.material.button.MaterialButton
            android:id="@+id/btn_3"
            style="@style/CalculatorButtonStyle"
            android:layout_marginTop="9dp"
            android:text="@string/btn_3"
            android:textColor="@color/input_text_color"
            android:textSize="32sp"
            android:fontFamily="@font/regular"
            android:background="@drawable/btn_bg_white"
            app:backgroundTint="@null"
            app:layout_constraintLeft_toRightOf="@id/gl_2"
            app:layout_constraintRight_toLeftOf="@id/gl_3"
            app:layout_constraintTop_toBottomOf="@id/btn_6" />

        <!-- Row 4 -->
        <com.google.android.material.button.MaterialButton
            android:id="@+id/btn_00"
            style="@style/CalculatorButtonStyle"
            android:layout_marginTop="9dp"
            android:text="@string/btn_00"
            android:textColor="@color/input_text_color"
            android:textSize="32sp"
            android:fontFamily="@font/regular"
            android:background="@drawable/btn_bg_white"
            app:backgroundTint="@null"
            app:layout_constraintLeft_toLeftOf="parent"
            app:layout_constraintRight_toLeftOf="@id/gl_1"
            app:layout_constraintTop_toBottomOf="@id/btn_1" />

        <com.google.android.material.button.MaterialButton
            android:id="@+id/btn_0"
            style="@style/CalculatorButtonStyle"
            android:layout_marginTop="9dp"
            android:text="@string/btn_0"
            android:textColor="@color/input_text_color"
            android:textSize="32sp"
            android:fontFamily="@font/regular"
            android:background="@drawable/btn_bg_white"
            app:backgroundTint="@null"
            app:layout_constraintLeft_toRightOf="@id/gl_1"
            app:layout_constraintRight_toLeftOf="@id/gl_2"
            app:layout_constraintTop_toBottomOf="@id/btn_2" />

        <com.google.android.material.button.MaterialButton
            android:id="@+id/btn_dot"
            style="@style/CalculatorButtonStyle"
            android:layout_marginTop="9dp"
            android:text="@string/btn_dot"
            android:textColor="@color/input_text_color"
            android:textSize="32sp"
            android:fontFamily="@font/regular"
            android:background="@drawable/btn_bg_white"
            app:backgroundTint="@null"
            app:layout_constraintLeft_toRightOf="@id/gl_2"
            app:layout_constraintRight_toLeftOf="@id/gl_3"
            app:layout_constraintTop_toBottomOf="@id/btn_3" />

        <!-- Equals button spanning 2 rows -->
        <com.google.android.material.button.MaterialButton
            android:id="@+id/btn_equals"
            style="@style/CalculatorButtonStyle"
            android:layout_width="85dp"
            android:layout_height="165dp"
            android:layout_marginTop="9dp"
            android:background="@drawable/btn_bg_orange"
            app:backgroundTint="@null"
            app:icon="@drawable/ic_equal_to"
            app:iconGravity="textStart"
            app:iconPadding="0dp"
            app:iconSize="34dp"
            app:iconTint="@color/white"
            android:contentDescription="@string/desc_equals"
            app:layout_constraintBottom_toBottomOf="@id/btn_dot"
            app:layout_constraintRight_toRightOf="parent"
            app:layout_constraintLeft_toRightOf="@id/gl_3"
            app:layout_constraintTop_toTopOf="@id/btn_3" />

    </androidx.constraintlayout.widget.ConstraintLayout>

</androidx.constraintlayout.widget.ConstraintLayout>