<resources xmlns:tools="http://schemas.android.com/tools">

    <style name="Base.Theme.QuickBazaar" parent="Theme.Material3.Light.NoActionBar">
        <item name="toolbarStyle">@style/Widget.App.Toolbar</item>
        <item name="android:textColorPrimary">@color/black</item>
        <item name="android:textColorSecondary">@color/text_secondary</item>
        <item name="android:windowBackground">@color/app_background</item>
        <item name="colorPrimary">@color/teal_dark</item>
        <item name="colorPrimaryDark">@color/teal_dark</item>
        <item name="colorAccent">@color/bread_orange</item>
        <item name="bottomNavigationStyle">@style/App.Custom.BottomNav</item>
    </style>

    <style name="Theme.QuickBazaar" parent="Base.Theme.QuickBazaar" />

    <style name="Widget.App.Toolbar" parent="Widget.Material3.Toolbar">
        <item name="titleTextAppearance">@style/TextAppearance.App.Toolbar.Title</item>
        <item name="background">@color/teal_dark</item>
        <item name="android:background">@color/teal_dark</item>
    </style>

    <style name="TextAppearance.App.Toolbar.Title" parent="TextAppearance.Material3.TitleLarge">
        <item name="android:textStyle">bold</item>
        <item name="android:textColor">@color/white</item>
    </style>

    <!-- Compact Optimized Bottom Nav Style -->
    <style name="App.Custom.BottomNav" parent="Widget.Material3.BottomNavigationView">
        <item name="itemIconTint">@color/nav_item_icon_color</item>
        <item name="itemTextColor">@color/nav_item_text_color</item>
        <item name="itemActiveIndicatorStyle">@style/App.Custom.Indicator</item>
        <item name="backgroundTint">@color/teal_dark</item>
        <item name="itemIconSize">20dp</item> <!-- Reduced for compactness -->
        <item name="labelVisibilityMode">labeled</item>
        <item name="itemTextAppearanceInactive">@style/App.NavText</item>
        <item name="itemTextAppearanceActive">@style/App.NavText</item>
    </style>

    <!-- Sleeker indicator to reduce total height -->
    <style name="App.Custom.Indicator" parent="Widget.Material3.BottomNavigationView.ActiveIndicator">
        <item name="android:color">#1AFFFFFF</item>
        <item name="android:width">52dp</item>
        <item name="android:height">28dp</item> <!-- Reduced height -->
        <item name="shapeAppearance">@style/App.Custom.Indicator.Shape</item>
    </style>

    <style name="App.NavText" parent="TextAppearance.Material3.LabelSmall">
        <item name="android:textSize">11sp</item> <!-- Slightly smaller text -->
        <item name="android:fontFamily">sans-serif-medium</item>
    </style>

    <style name="App.Custom.Indicator.Shape">
        <item name="cornerFamily">rounded</item>
        <item name="cornerSize">50%</item>
    </style>

    <style name="ShapeAppearance.App.TopRounded" parent="ShapeAppearance.Material3.MediumComponent">
        <item name="cornerFamily">rounded</item>
        <item name="cornerSizeTopLeft">24dp</item>
        <item name="cornerSizeTopRight">24dp</item>
        <item name="cornerSizeBottomLeft">0dp</item>
        <item name="cornerSizeBottomRight">0dp</item>
    </style>

</resources>