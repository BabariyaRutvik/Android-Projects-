<?xml version="1.0" encoding="utf-8"?>
<androidx.constraintlayout.widget.ConstraintLayout xmlns:android="http://schemas.android.com/apk/res/android"
    xmlns:app="http://schemas.android.com/apk/res-auto"
    xmlns:tools="http://schemas.android.com/tools"
    android:layout_width="match_parent"
    android:layout_height="match_parent"
    android:background="@color/app_background"
    tools:context=".BazaarFragment.HomeFragment">

    <androidx.core.widget.NestedScrollView
        android:layout_width="match_parent"
        android:layout_height="match_parent"
        android:fillViewport="true">

        <androidx.constraintlayout.widget.ConstraintLayout
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:paddingBottom="20dp">

            <LinearLayout
                android:id="@+id/linear_header"
                android:layout_width="match_parent"
                android:layout_height="wrap_content"
                android:orientation="horizontal"
                android:padding="20dp"
                android:gravity="center_vertical"
                app:layout_constraintTop_toTopOf="parent"
                android:background="?attr/colorSurface"
                android:elevation="4dp">

                <LinearLayout
                    android:layout_width="0dp"
                    android:layout_height="wrap_content"
                    android:orientation="vertical"
                    android:layout_weight="1">

                    <TextView
                        android:id="@+id/text_user_greetings"
                        android:layout_width="wrap_content"
                        android:layout_height="wrap_content"
                        android:text="Hi, User 👋"
                        android:textColor="?attr/colorOnSurface"
                        android:textStyle="bold"
                        android:textSize="20sp"
                        android:fontFamily="sans-serif-black" />

                    <TextView
                        android:id="@+id/text_user_location"
                        android:layout_width="wrap_content"
                        android:layout_height="wrap_content"
                        android:text="Your Location"
                        android:textColor="?android:attr/textColorSecondary"
                        android:textSize="12sp"
                        android:drawablePadding="4dp"
                        app:drawableStartCompat="@drawable/ic_location"
                        app:drawableTint="?attr/colorPrimary" />

                </LinearLayout>

                <!-- AI Assistant Icon -->
                <ImageView
                    android:id="@+id/img_ai_chat"
                    android:layout_width="40dp"
                    android:layout_height="40dp"
                    android:layout_marginEnd="8dp"
                    android:background="@drawable/google_btn_bg"
                    android:padding="8dp"
                    android:src="@drawable/ic_ai_sparkle"
                    app:tint="@color/teal_dark"
                    android:contentDescription="AI Assistant" />

                <!-- Notification Icon with Badge -->
                <FrameLayout
                    android:id="@+id/frame_notification"
                    android:layout_width="wrap_content"
                    android:layout_height="wrap_content">

                    <ImageView
                        android:id="@+id/img_notification"
                        android:layout_width="40dp"
                        android:layout_height="40dp"
                        android:background="@drawable/google_btn_bg"
                        android:padding="8dp"
                        android:src="@drawable/ic_notifications"
                        app:tint="@color/teal_dark"
                        android:contentDescription="Notifications" />

                    <TextView
                        android:id="@+id/tv_notification_badge"
                        android:layout_width="18dp"
                        android:layout_height="18dp"
                        android:layout_gravity="top|end"
                        android:background="@drawable/badge_circle"
                        android:gravity="center"
                        android:text="0"
                        android:textColor="@android:color/white"
                        android:textSize="10sp"
                        android:textStyle="bold"
                        android:visibility="gone" />

                </FrameLayout>

            </LinearLayout>

            <com.google.android.material.card.MaterialCardView
                android:id="@+id/card_searchview"
                android:layout_width="match_parent"
                android:layout_height="wrap_content"
                app:layout_constraintTop_toBottomOf="@id/linear_header"
                android:layout_marginHorizontal="20dp"
                android:layout_marginTop="12dp"
                app:cardCornerRadius="14dp"
                app:cardElevation="4dp"
                app:cardBackgroundColor="?attr/colorSurface"
                app:strokeWidth="0dp">
                <EditText
                    android:id="@+id/et_search"
                    android:layout_width="match_parent"
                    android:layout_height="54dp"
                    android:background="@android:color/transparent"
                    app:drawableStartCompat="@drawable/ic_search"
                    app:drawableTint="?attr/colorPrimary"
                    android:drawablePadding="12dp"
                    android:hint="Search products..."
                    android:textColorHint="?android:attr/textColorSecondary"
                    android:textColor="?attr/colorOnSurface"
                    android:paddingHorizontal="16dp"
                    android:textSize="15sp"
                    android:inputType="text"
                    android:autofillHints="none" />
            </com.google.android.material.card.MaterialCardView>

            <TextView
                android:id="@+id/text_cat_label"
                android:layout_width="wrap_content"
                android:layout_height="wrap_content"
                app:layout_constraintTop_toBottomOf="@id/card_searchview"
                app:layout_constraintStart_toStartOf="parent"
                android:text="Categories"
                android:layout_marginStart="20dp"
                android:layout_marginTop="16dp"
                android:textSize="18sp"
                android:textStyle="bold"
                android:textColor="?attr/colorPrimary"
                android:fontFamily="sans-serif-black" />

            <androidx.recyclerview.widget.RecyclerView
                android:id="@+id/recycerview_category"
                android:layout_width="match_parent"
                android:layout_height="wrap_content"
                app:layout_constraintTop_toBottomOf="@id/text_cat_label"
                android:layout_marginTop="8dp"
                android:orientation="horizontal"
                app:layoutManager="androidx.recyclerview.widget.LinearLayoutManager"
                android:paddingHorizontal="16dp"
                android:clipToPadding="false"
                tools:listitem="@layout/item_category" />

            <androidx.cardview.widget.CardView
                android:id="@+id/card_banner"
                android:layout_width="match_parent"
                android:layout_height="130dp"
                android:layout_marginHorizontal="20dp"
                app:layout_constraintTop_toBottomOf="@id/recycerview_category"
                android:layout_marginTop="16dp"
                app:cardCornerRadius="16dp"
                app:cardMaxElevation="4dp">
                <ImageView
                    android:layout_width="match_parent"
                    android:layout_height="match_parent"
                    android:scaleType="centerCrop"
                    android:src="@drawable/ic_grocery_cart"
                    android:background="@color/teal_light"
                    android:contentDescription="Promotions" />
            </androidx.cardview.widget.CardView>

            <TextView
                android:id="@+id/text_popular_label"
                android:layout_width="wrap_content"
                android:layout_height="wrap_content"
                app:layout_constraintTop_toBottomOf="@id/card_banner"
                app:layout_constraintStart_toStartOf="parent"
                android:text="Popular Product"
                android:layout_marginStart="20dp"
                android:layout_marginTop="16dp"
                android:textColor="?attr/colorPrimary"
                android:textSize="18sp"
                android:textStyle="bold"
                android:fontFamily="sans-serif-black" />

            <androidx.recyclerview.widget.RecyclerView
                android:id="@+id/recycerview_popular_products"
                android:layout_width="match_parent"
                android:layout_height="wrap_content"
                android:layout_marginTop="12dp"
                android:paddingHorizontal="12dp"
                app:layoutManager="androidx.recyclerview.widget.GridLayoutManager"
                app:spanCount="2"
                app:layout_constraintTop_toBottomOf="@id/text_popular_label"
                tools:listitem="@layout/item_product" />

        </androidx.constraintlayout.widget.ConstraintLayout>
    </androidx.core.widget.NestedScrollView>

</androidx.constraintlayout.widget.ConstraintLayout>